                                    <?= /* @noEscape */ $svgDot ?>
                                    <?= $escaper->escapeHtml(__('Production starts immediately')) ?>
                                </span>

                            <?php else: ?>
                                <!-- Healthy stock — direct availability -->
                                <span class="inline-flex items-center gap-1 text-sm font-semibold text-techtic-lime-green">
