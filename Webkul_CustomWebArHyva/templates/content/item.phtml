// ── Date calculations (mirrors PDP stock.phtml exactly) ──────────────────────
$cjmExpDate  = trim((string) $cjmExpDate);
$isValidDate = !empty($cjmExpDate);
$timestamp   = 0;
$isExpired   = false;
$visibleDate = null;

if ($isValidDate) {
    $timestamp = strtotime($cjmExpDate);
    if ($timestamp === false) {
        $isValidDate = false;
        $timestamp   = 0;
    } else {
        $isExpired = $timestamp <= (time() + 3 * 24 * 60 * 60);
        try {
            $formatter   = new IntlDateFormatter('nl_NL', IntlDateFormatter::LONG, IntlDateFormatter::NONE);
            $visibleDate = $formatter->format($timestamp);
        } catch (Exception $e) {
            $visibleDate = date('j F Y', $timestamp);
        }
    }
}
$showDateInfo = $isValidDate && !$isExpired;

// Delivery times >= 2 weeks — these should NOT show "Directly Available"
