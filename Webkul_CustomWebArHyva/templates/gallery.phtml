    <script>
        // ============ WebAR Configurations ============
        var webarOptions = {
            "mainImageData": "<?= /* @noEscape */ $mainImageData ?>",
            "showCustomImageInThumbnail": <?= /* @noEscape */ $showCustomImageInThumbnail ?>,
            "modelUrl": "<?= /* @noEscape */ $modelUrl ?>",
            "iosModelUrl": "<?= /* @noEscape */ $iosModelUrl ?>",
            "displayModel": <?= /* @noEscape */ $display ? 'true' : 'false' ?>,
            "isArProduct": <?= /* @noEscape */ $isArProduct ? 'true' : 'false' ?>,
            "attributeConfigs": <?= /* @noEscape */ $attrConfigJson ?>,
            "productHasOptions": <?= /* @noEscape */ (int)$product->hasOptions() ?? 0 ?>,
            "showCustomButton": <?= /* @noEscape */ (int)$btnConfig["showCustomButton"] ?? 0 ?>,
            "showCustomButtonText": "<?= /* @noEscape */ $btnConfig["configButtonText"] ?>",
            "showSeperateGlb": <?= /* @noEscape */ $showSeperateGlb ?>,
            "associatedProducts": <?= /* @noEscape */ $associatedProductsJson ?>,
            "productType": "<?= /* @noEscape */ $productType ?>",
            "defaultVariantAttribute": <?= /* @noEscape */ $defaultVariantAttribute ?>,
            "modelViewerScriptUrl": "<?= /* @noEscape */ $block->getViewFileUrl('Webkul_WebAr::js/webxr/mv/model-viewer.min.js') ?>",
            "isCartConfigure": <?= $isCartConfigure ? 'true' : 'false' ?>
        };

        var modelThumbnailImg = "<?= /* @noEscape */ $modelThumbnailImg ?>";

        // Lazy load model-viewer script
        var modelViewerScriptLoaded = false;

        function loadModelViewerScript() {
            return new Promise((resolve, reject) => {
                if (modelViewerScriptLoaded) {
                    resolve();
                    return;
                }

                const script = document.createElement('script');
                script.type = 'module';
                script.src = webarOptions.modelViewerScriptUrl;
                script.onload = () => {
                    modelViewerScriptLoaded = true;
                    resolve();
                };
                script.onerror = reject;
                document.head.appendChild(script);
            });
        }

        function initGallery() {
            return {
                activeItem: 0,
                activeVideo: false,
                itemIsVideo: false,
                itemIsAr: false,
                itemCount: 0,
                fullscreen: false,
                focusTrapListener: null,
                loop: <?= $galleryOptionLoop ? 'true' : 'false' ?>,
                isStart: true,
                isEnd: false,
                showQrModal: false,
                qrCodeLoaded: false,
                qrCodeHtml: '',
                isSafari: false,
                show3DModel: false,
                modelRendered: false,
                modelLoaded: false,
                isArAvailable: false,
                videoOptions: {
                    autoplay: <?= $galleryOptionVideoAutoplay ? 'true' : 'false' ?>,
                    loop: <?= $galleryOptionVideoLoop ? 'true' : 'false' ?>,
                    showRelated: <?= $galleryOptionShowRelated ? 'true' : 'false' ?>,
                    allowApi: false
                },
                swipeStart: 0,
                swipeDir: "x",
                <?php if ($galleryOptionShowMagnifier): ?>
                    showMagnifier: <?= $galleryOptionShowMagnifierBtn ? 'false' : 'true' ?>,
                    showMagnifierButton: <?= $galleryOptionShowMagnifierBtn ? 'true' : 'false' ?>,
                <?php endif; ?>
                initialImages: <?= /* @noEscape */ $block->getGalleryImagesJson() ?>,
                images: <?= /* @noEscape */ $block->getGalleryImagesJson() ?>,

                init() {
                    // ── CART CONFIGURE BYPASS ──────────────────────────────────
                    // On checkout_cart_configure, skip ALL Webkul/AR/magnifier
                    // initialisation so MageWorx APO can load without conflicts.
                    if (webarOptions.isCartConfigure) {
                        this.isArAvailable = false;
                        this.itemCount = this.images.length;
                        this.initActive();
                        this.$watch('activeItem', () => {
                            this.updateActiveItem();
                        });
                        return; // <-- bail out early, no AR/model-viewer/magnifier
                    }
                    // ── END BYPASS ─────────────────────────────────────────────

                    // Detect Safari browser
                    this.isSafari = this.detectSafari();

                    // Set AR availability flag
                    this.isArAvailable = webarOptions.isArProduct && (webarOptions.modelUrl || webarOptions.iosModelUrl);

                    // DO NOT add AR model to images array - keep original images only
                    this.initialImages = [...this.images];
                    this.itemCount = this.images.length;
                    this.initActive();

                    this.$watch('activeItem', (item) => {
                        this.updateActiveItem();
                    });

                    this.$watch('itemCount', () => {
                        this.calcThumbsOverflow()
                    });

                    this.$watch('fullscreen', (open) => {
                        <?php if ($galleryOptionShowMagnifier): ?>
                            this.showMagnifier = <?= $galleryOptionShowMagnifierBtn ? 'false' : '!open && !this.show3DModel' ?>;
                            this.showMagnifierButton = <?= !$galleryOptionShowMagnifierBtn
                                                            ? 'open'
                                                            : ($galleryOptionShowFullscreenBtn ? 'true' : '!open') ?>;
                        <?php endif; ?>
                        this.$nextTick(() => {
                            this.scrollLock(open);
                            this.tabLock(this.$refs.galleryDialog, open);
                        })
                    })

                    // Watch for QR modal changes
                    this.$watch('showQrModal', (show) => {
                        if (show) {
                            document.body.style.overflow = 'hidden';
                            this.loadQRCode();
                        } else {
                            document.body.style.overflow = '';
                        }
                    });

                    // Watch for 3D model state
                    this.$watch('show3DModel', (show) => {
                        if (!show) {
                            // Reset to first image when closing 3D model
                            if (this.activeItem === 0) {
                                this.$nextTick(() => {
                                    this.updateActiveItem();
                                });
                            }
                        }
                    });
                },

                // Detect Safari browser
                detectSafari() {
                    const ua = navigator.userAgent.toLowerCase();
                    const isSafari = ua.indexOf('safari') !== -1 &&
                        ua.indexOf('chrome') === -1 &&
                        ua.indexOf('android') === -1;
                    return isSafari;
                },

                // Lazy load 3D model
                async load3DModel() {
                    if (!this.isArAvailable) return;

                    this.show3DModel = true;

                    // Add AR model to thumbnail gallery if not already added
                    const hasArModel = this.images.some(img => img.isArModel === true);
                    if (!hasArModel && webarOptions.isArProduct && webarOptions.modelUrl) {
                        const arModelImage = {
                            thumb: modelThumbnailImg,
                            img: modelThumbnailImg,
                            full: modelThumbnailImg,
                            caption: '3D Model',
                            isArModel: true,
                            type: 'ar-model',
                            isMain: false
                        };
                        // Add to beginning of images array
                        this.images = [arModelImage, ...this.images];
                        this.itemCount = this.images.length;

                        // Switch to the AR model thumbnail (index 0)
                        this.activeItem = 0;

                        // Recalculate thumbnail overflow
                        this.$nextTick(() => {
                            this.calcThumbsOverflow();
                        });
                    } else if (hasArModel) {
                        // If AR model already exists, just switch to it
                        const arModelIndex = this.images.findIndex(img => img.isArModel === true);
                        if (arModelIndex !== -1) {
                            this.activeItem = arModelIndex;
                        }
                    }

                    // Load and render 3D model
                    if (!this.modelRendered) {
                        try {
                            // Load model-viewer script first
                            await loadModelViewerScript();

                            // Small delay to ensure script is fully loaded
                            await new Promise(resolve => setTimeout(resolve, 100));

                            this.$nextTick(() => {
                                this.render3DModel();
                                this.modelRendered = true;
                            });
                        } catch (error) {
                            console.error('Failed to load model-viewer:', error);
                        }
                    }
                },

                hide3DModel() {
                    this.show3DModel = false;
                    // Remove AR model from gallery when hiding 3D model
                    const arModelIndex = this.images.findIndex(img => img.isArModel === true);
                    if (arModelIndex !== -1) {
                        this.images.splice(arModelIndex, 1);
                        this.itemCount = this.images.length;
                        // Switch to first regular image
                        this.activeItem = 0;
                        this.$nextTick(() => {
                            this.calcThumbsOverflow();
                        });
                    }
                },

                handleThumbnailClick(image) {
                    if (image.isArModel) {
                        // If AR model thumbnail is clicked, show 3D model
                        this.show3DModel = true;
                        if (!this.modelRendered) {
                            this.load3DModel();
                        }
                    } else {
                        // If regular image thumbnail is clicked, hide 3D model
                        this.show3DModel = false;
                    }
                },

                // Lazy load QR Code
                async loadQRCode() {
                    if (this.qrCodeLoaded) return;

                    try {
                        <?php $qrCodeDataUri = $block->getProductQrCode(); ?>
                        <?php if ($qrCodeDataUri): ?>
                            this.qrCodeHtml = `<img src="<?= /* @noEscape */ $qrCodeDataUri ?>" 
                                alt="<?= $escaper->escapeHtmlAttr(__('QR Code for %1', $productName)) ?>"
                                class="w-64 h-64"
                                width="256"
                                height="256">`;
                        <?php else: ?>
                            this.qrCodeHtml = '<p class="text-red-500 text-center"><?= $escaper->escapeHtml(__('Unable to generate QR code')) ?></p>';
                        <?php endif; ?>

                        this.qrCodeLoaded = true;
                    } catch (error) {
                        console.error('Failed to load QR code:', error);
                        this.qrCodeHtml = '<p class="text-red-500 text-center">Error loading QR code</p>';
                        this.qrCodeLoaded = true;
                    }
                },

                async handleARView() {
                    if (!this.isArAvailable) return;

                    const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

                    if (isMobile) {
                        // On mobile, load the 3D model and trigger AR view
                        if (!this.modelRendered) {
                            this.show3DModel = true;
                            try {
                                await loadModelViewerScript();
                                await new Promise(resolve => setTimeout(resolve, 100));

                                this.$nextTick(() => {
                                    this.render3DModel();
                                    this.modelRendered = true;

                                    // Wait for model-viewer to fully load, then trigger AR
                                    setTimeout(() => {
                                        const modelViewer = document.getElementById('wk3dimage');
                                        if (modelViewer) {
                                            // Check if model is loaded
                                            if (modelViewer.loaded) {
                                                this.triggerAR(modelViewer);
                                            } else {
                                                // Wait for model to load
                                                modelViewer.addEventListener('load', () => {
                                                    this.triggerAR(modelViewer);
                                                }, {
                                                    once: true
                                                });
                                            }
                                        }
                                    }, 1000);
                                });
                            } catch (error) {
                                console.error('Failed to load AR:', error);
                            }
                        } else {
                            // Model already loaded, just trigger AR
                            this.show3DModel = true;
                            this.$nextTick(() => {
                                const modelViewer = document.getElementById('wk3dimage');
                                if (modelViewer) {
                                    this.triggerAR(modelViewer);
                                }
                            });
                        }
                    } else {
                        // On desktop, show QR code modal
                        this.showQrModal = true;
                    }
                },

                triggerAR(modelViewer) {
                    const arButton = modelViewer.querySelector('#ar-button');
                    if (arButton) {
                        arButton.click();
                    } else if (modelViewer.activateAR) {
                        modelViewer.activateAR();
                    }
                },

                updateActiveItem() {
                    const item = this.activeItem;
                    const currentImage = this.images[item];
                    this.itemIsVideo = currentImage?.type === 'video';
                    this.itemIsAr = currentImage?.isArModel === true;
                    this.activeVideo = this.itemIsVideo && this.videoOptions.autoplay;
                    this.isStart = this.activeItem === 0;
                    this.isEnd = this.activeItem === (this.itemCount - 1);

                    // If current item is AR model, ensure 3D model is shown
                    if (this.itemIsAr && !this.show3DModel) {
                        this.show3DModel = true;
                        if (!this.modelRendered) {
                            this.load3DModel();
                        }
                    }

                    // Hide 3D model when switching to non-AR images
                    if (!this.itemIsAr && this.show3DModel) {
                        this.show3DModel = false;
                    }

                    <?php if ($galleryOptionShowMagnifier): ?>
                        this.showMagnifier = <?= $galleryOptionShowMagnifierBtn
                                                    ? 'false'
                                                    : '!this.fullscreen && !this.itemIsVideo && !this.show3DModel' ?>;
                    <?php endif; ?>

                    <?php if ($galleryOptionShowThumbs): ?>
                        this.$nextTick(() => {
                            const activeThumb = this.getActiveThumb();
                            if (activeThumb) {
                                this.scrollTo(activeThumb);
                            }
                        });
                    <?php endif; ?>
                },

                render3DModel() {
                    const container = document.getElementById('wk3dimage-container');
                    if (!container || !webarOptions.modelUrl) return;

                    this.isSafari = this.detectSafari();
                    this.modelLoaded = false;

                    let viewerHtml = '<model-viewer id="wk3dimage" ';
                    viewerHtml += 'data-js-focus-visible ';
                    viewerHtml += 'src="' + webarOptions.modelUrl + '" ';
                    viewerHtml += 'alt="A 3D model of a product" ';
                    viewerHtml += 'camera-controls ';
                    viewerHtml += 'camera-orbit="33deg 67deg auto" ';
                    viewerHtml += 'style="width: 100%; height: 100%;" ';

                    if (webarOptions.productHasOptions) {
                        viewerHtml += 'ar ar-modes="webxr quick-look" ';
                    } else {
                        viewerHtml += 'ar ar-modes="scene-viewer webxr quick-look" ';
                    }

                    // Apply attribute configurations
                    const attrs = webarOptions.attributeConfigs;

                    if (attrs.auto_rotate == 1) {
                        viewerHtml += ' auto-rotate ';
                        if (attrs.auto_rotate_delay != '') {
                            viewerHtml += ' auto-rotate-delay="' + attrs.auto_rotate_delay + '" ';
                        }
                    }
                    if (attrs.disable_zoom == 1) {
                        viewerHtml += ' disable-zoom ';
                    }
                    if (attrs.disable_tap == 1) {
                        viewerHtml += ' disable-tap ';
                    }
                    if (attrs.touch_action != '') {
                        viewerHtml += ' touch-action="' + attrs.touch_action + '" ';
                    }
                    if (attrs.interpolation_decay != '') {
                        viewerHtml += ' interpolation-decay="' + attrs.interpolation_decay + '" ';
                    }
                    if (attrs.shadow_intensity != '-1') {
                        viewerHtml += ' shadow-intensity="' + attrs.shadow_intensity + '" ';
                    }
                    if (attrs.exposure != '-1') {
                        viewerHtml += ' exposure="' + attrs.exposure + '" ';
                    }
                    if (attrs.shadow_softness != '-1') {
                        viewerHtml += ' shadow-softness="' + attrs.shadow_softness + '" ';
                    }
                    if (attrs.apply_environment_image == 1) {
                        if (attrs.environment_image != '' && attrs.environment_image != 'envurl') {
                            viewerHtml += ' environment-image="' + attrs.environment_image + '" ';
                        } else if (attrs.environment_image == 'envurl' && attrs.environment_image_url != '') {
                            viewerHtml += ' environment-image="' + attrs.environment_image_url + '" ';
                        }
                    }
                    if (attrs.skybox_image != '' && attrs.apply_skybox_image != 0) {
                        viewerHtml += ' skybox-image="' + attrs.skybox_image + '" ';
                    }
                    if (attrs.loading != '') {
                        viewerHtml += ' loading="' + attrs.loading + '" ';
                    }
                    if (attrs.poster != '') {
                        viewerHtml += ' poster="' + attrs.poster + '" ';
                    }
                    if (webarOptions.iosModelUrl != "") {
                        viewerHtml += ' ios-src="' + webarOptions.iosModelUrl + '" ';
                    }

                    viewerHtml += '>';

                    if (webarOptions.showCustomButton) {
                        if (this.isSafari && webarOptions.iosModelUrl) {
                            viewerHtml += `
                                <button id="ar-button" class="ar-custom-button md:hidden"
                                    onclick="window.location.href='${webarOptions.iosModelUrl}'">
                                    ${webarOptions.showCustomButtonText}
                                </button>`;
                        } else {
                            viewerHtml += `
                            <button slot="ar-button" id="ar-button">
                                ${webarOptions.showCustomButtonText}
                            </button>`;
                        }
                    } else {
                        if (this.isSafari && webarOptions.iosModelUrl) {
                            viewerHtml += `
                                <button id="ar-button" class="ar-custom-button md:hidden"
                                    onclick="window.location.href='${webarOptions.iosModelUrl}'">
                                    View in your room
                                </button>`;
                        }
                    }

                    viewerHtml += '<div class="slot ar-button ar-qr-button-container">';
                    viewerHtml += '<button slot="ar-button" id="ar-button" class="ar-qr-button hidden md:block" ';
                    viewerHtml += 'onclick="window.dispatchEvent(new CustomEvent(\'open-qr-modal\'))">';
                    viewerHtml += webarOptions.showCustomButtonText;
                    viewerHtml += '</button></div>';
                    viewerHtml += '</model-viewer>';

                    container.innerHTML = viewerHtml;

                    // Wait for model to load
                    this.$nextTick(() => {
                        const modelViewer = document.getElementById('wk3dimage');
                        if (modelViewer) {
                            modelViewer.addEventListener('load', () => {
                                this.modelLoaded = true;
                            });

                            // Fallback timeout
                            setTimeout(() => {
                                this.modelLoaded = true;
                            }, 3000);
                        }
                    });

                    if (this.isSafari && webarOptions.showCustomButton) {
                        this.$nextTick(() => {
                            this.hideDefaultArButton();
                        });
                    }
                },

                hideDefaultArButton() {
                    const modelViewer = document.getElementById('wk3dimage');
                    if (!modelViewer) return;

                    // Add CSS to hide the default AR button
                    const style = document.createElement('style');
                    style.textContent = `
                        #wk3dimage::part(default-ar-button) {
                            display: none !important;
                        }
                    `;
                    document.head.appendChild(style);
                },

                openQrModal() {
                    this.showQrModal = true;
                },

                scrollLock(use = true) {
                    document.body.style.overflow = use ? "hidden" : "";
                },

                tabLock(target, use = true) {
                    if (use) {
                        hyva.trapFocus(target);
                    } else {
                        hyva.releaseFocus(target);
                    }
                },

                nextItem() {
                    const hasNext = this.activeItem < (this.itemCount - 1);
                    this.activeItem = hasNext ?
                        this.activeItem += 1 :
                        this.loop ? 0 : this.activeItem;
                },

                prevItem() {
                    const hasPrev = this.activeItem > 0;
                    this.activeItem = hasPrev ?
                        this.activeItem -= 1 :
                        this.loop ? (this.itemCount - 1) : this.activeItem;
                },

                swipeItem(event) {
                    if (this.swipeStart === 0) return;
                    const swipeEnd = this.getTouchPosition(event);
                    if (Math.abs((swipeEnd - this.swipeStart)) < 40) return;

                    if (this.swipeStart > swipeEnd) {
                        this.nextItem();
                    } else {
                        this.prevItem();
                    }
                    this.swipeStart = 0;
                },

                getVideoData(source) {
                    const videoUrl = source.videoUrl;
                    const videoData = {
                        id: null,
                        type: null,
                        src: null,
                        additionalParams: "&autoplay=1",
                        allow: "fullscreen; picture-in-picture; autoplay;"
                    }
                    if (!videoUrl) return videoData;

                    if (this.videoOptions.loop) {
                        videoData.additionalParams += '&loop=1';
                    }

                    if (videoUrl.match(/youtube\.com|youtu\.be|youtube-nocookie.com/)) {
                        const youtubeRegex = /^.*(?:(?:youtu\.be\/|v\/|vi\/|u\/\w\/|embed\/)|(?:(?:watch)?\?v(?:i)?=|\&v(?:i)?=))([^#\&\?]*).*/;
                        const baseSrc = videoUrl.match(/youtube-nocookie.com/) ?
                            'https://www.youtube-nocookie.com/embed' :
                            'https://www.youtube.com/embed';

                        videoData.type = "youtube";
                        videoData.id = videoUrl.match(youtubeRegex)[1];
                        videoData.additionalParams += (this.videoOptions.showRelated ? '&rel=1' : '&rel=0');

                        if (this.videoOptions.loop) {
                            videoData.additionalParams += `&playlist=${videoData.id}`
                        }
                        if (this.videoOptions.allowApi) {
                            videoData.additionalParams += '&enablejsapi=1';
                        }

                        videoData.src = `${baseSrc}/${videoData.id}?origin=<?= $block->getBaseUrl() ?>${videoData.additionalParams}`;
                        videoData.allow += " accelerometer; clipboard-write; encrypted-media; gyroscope;"
                    } else if (videoUrl.match(/vimeo\.com/)) {
                        const vimeoRegex = new RegExp([
                            'https?:\\/\\/(?:www\\.|player\\.)?vimeo.com\\/(?:channels\\/(?:\\w+\\/)',
                            '?|groups\\/([^\\/]*)\\/videos\\/|album\\/(\\d+)\\/video\\/|video\\/|)(\\d+)(?:$|\\/|\\?)'
                        ].join(''));
                        const timestamp = new Date().getTime();
                        const baseSrc = "https://player.vimeo.com/video";

                        videoData.type = "vimeo";
                        videoData.id = videoUrl.match(vimeoRegex)[3];
                        if (this.videoOptions.allowApi) {
                            videoData.additionalParams += "&api=1"
                        }
                        videoData.src = `${baseSrc}/${videoData.id}?player_id=vimeo${videoData.id}${timestamp}${videoData.additionalParams}`;
                    }

                    return videoData;
                },

                getTouchPosition(event) {
                    const position = this.swipeDir === "y" ?
                        event.changedTouches[0].clientY :
                        event.changedTouches[0].clientX;
                    return Math.round(position);
                },

                isSwipeGesture(event) {
                    return event.touches.length <= 1 && window.visualViewport.scale <= 1.01;
                },

                receiveImages(images) {
                    <?php if ($galleryOptionAppendOnReceive): ?>
                        const initialUrls = this.initialImages.map(image => image.full);
                        const newImages = images.filter(image => !initialUrls.includes(image.full));

                        this.images = [].concat(this.initialImages, newImages);
                        this.activeItem = newImages.length ? this.initialImages.length : 0;
                    <?php else: ?>
                        this.images = images;
                        this.activeItem = 0;
                    <?php endif; ?>

                    this.itemCount = this.images.length;

                    this.$nextTick(() => {
                        this.updateActiveItem();
                    });
                },

                updateArModel(detail) {
                    if (!webarOptions.showSeperateGlb || !webarOptions.associatedProducts) return;

                    const productId = detail.productIndex;
                    const associatedProducts = webarOptions.associatedProducts;

                    if (associatedProducts[productId]) {
                        const newModelUrl = associatedProducts[productId].modelUrl || '';
                        const newIosModelUrl = associatedProducts[productId].iosModelUrl || '';

                        if (webarOptions.modelUrl !== newModelUrl || webarOptions.iosModelUrl !== newIosModelUrl) {
                            webarOptions.modelUrl = newModelUrl;
                            webarOptions.iosModelUrl = newIosModelUrl;

                            // Update AR availability
                            this.isArAvailable = webarOptions.isArProduct && (webarOptions.modelUrl || webarOptions.iosModelUrl);

                            // Reset model state when URL changes
                            this.modelRendered = false;
                            this.show3DModel = false;
                            this.modelLoaded = false;
                        }
                    }
                },

                resetGallery() {
                    this.images = [...this.initialImages];
                    this.itemCount = this.images.length;
                    this.initActive();

                    // Reset model state
                    this.show3DModel = false;
                    this.modelRendered = false;
                    this.modelLoaded = false;
                },

                initActive() {
                    const mainImg = this.images.findIndex(image => image.isMain === true);
                    this.activeItem = mainImg === -1 ? 0 : mainImg;
                },

                eventListeners: {
                    ['@keydown.window.escape']() {
                        this.fullscreen = false;
                        this.showQrModal = false;
                    },
                    ['@open-qr-modal.window']() {
                        this.showQrModal = true;
                    },
                    ['@update-gallery.window'](event) {
                        this.receiveImages(event.detail);
                    },
                    ['@configurable-selection-changed.window'](event) {
                        this.updateArModel(event.detail);
                    },
                    ['@reset-gallery.window']() {
                        this.resetGallery();
                    },
                },

                galleryBody: {
                    ['@touchstart.passive'](event) {
                        this.swipeStart = this.isSwipeGesture(event) ?
                            this.getTouchPosition(event) :
                            0;
                    },
                    ['@touchend.passive'](event) {
                        if (!this.isSwipeGesture(event)) return;
                        this.swipeItem(event);
                    },
                },

                <?php if ($galleryOptionShowThumbs): ?>
                    thumbsOverflow: false,
                    thumbsStart: true,
                    thumbsEnd: true,

                    scrollTo(target) {
                        target.scrollIntoView({
                            behavior: "smooth",
                            block: "nearest",
                            inline: "nearest"
                        });
                    },

                    getActiveThumb() {
                        return this.$refs.jsThumbSlides.querySelector('button[aria-current="true"]');
                    },

                    isThumbInView(index, action = "leave") {
                        const isFirst = index === 0;
                        const isLast = index === (this.itemCount - 1);

                        if (isFirst) {
                            this.thumbsStart = (action === "enter");
                        }
                        if (isLast) {
                            this.thumbsEnd = (action === "enter");
                        }
                    },

                    calcThumbsOverflow() {
                        const thumbs = this.$refs.jsThumbSlides;
                        if (!thumbs) return;

                        const {
                            scrollWidth,
                            scrollHeight,
                            offsetWidth,
                            offsetHeight
                        } = thumbs;
                        const hasOverflow = scrollHeight > scrollWidth ?
                            scrollHeight > offsetHeight :
                            scrollWidth > offsetWidth;

                        this.thumbsOverflow = hasOverflow;
                    },
                <?php endif; ?>
            }
        }
    </script>

    <?php if ($galleryOptionShowMagnifier): ?>
        <script>
            (() => {
                function alpine_magnifier(el) {
                    Alpine.directive("magnifier", (el, {
                        expression,
                        modifiers
                    }, {
                        evaluateLater,
                        effect,
                        cleanup
                    }) => {
                        const isHoverableDevice = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
                        const zoomSize = parseInt(modifierValue(modifiers, "zoom", 120)) + 100;
                        const getImageSrc = evaluateLater(expression);
                        let imageSrc;

                        effect(() => {
                            getImageSrc(img => {
                                imageSrc = img || null
                            });
                            el.style.setProperty("--zoom-src", imageSrc ? `url(${imageSrc})` : null);
                        });

                        el.addEventListener('mouseleave', resetZoom, false);
                        el.addEventListener('mousemove', updateZoom, false);

                        cleanup(() => {
                            el.removeEventListener('mouseleave', resetZoom);
                            el.removeEventListener('mousemove', updateZoom);
                        });

                        function resetZoom(e) {
                            el.style.setProperty("--zoom", null);
                            el.style.setProperty("--zoom-y", null);
                            el.style.setProperty("--zoom-x", null);
                        }

                        function updateZoom(e) {
                            if (!imageSrc || !isHoverableDevice) return;
                            const dimensions = this.getBoundingClientRect();
                            const xPercent = Math.round(100 / (dimensions.width / (e.clientX - dimensions.left)));
                            const yPercent = Math.round(100 / (dimensions.height / (e.clientY - dimensions.top)));
                            el.style.setProperty("--zoom", `${zoomSize}%`);
                            el.style.setProperty("--zoom-y", `${yPercent}%`);
                            el.style.setProperty("--zoom-x", `${xPercent}%`);
                        }
                    });
                }

                function alpine_magnifier_target(el) {
                    Alpine.directive("magnifier-target", (el, {}, {
                        evaluate
                    }) => {
                        el.style.position = "absolute";
                        el.style.inset = 0;
                        el.style.background = "var(--zoom-src) var(--zoom-x) var(--zoom-y)/var(--zoom) no-repeat";
                    });
                }

                function modifierValue(modifiers, key, fallback) {
                    if (modifiers.indexOf(key) === -1) return fallback;
                    const value = modifiers[modifiers.indexOf(key) + 1];
                    return value || fallback;
                }

                document.addEventListener("alpine:init", () => {
                    // Do not register magnifier plugins on cart configure page \u2014
                    // they interfere with MageWorx APO Alpine initialisation.
                    if (typeof webarOptions !== 'undefined' && webarOptions.isCartConfigure) {
                        return;
                    }
                    window.Alpine.plugin(alpine_magnifier);
                    window.Alpine.plugin(alpine_magnifier_target);
                });
            })();
        </script>
    <?php endif; ?>
</div>