use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\StoreConfig;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Magento\Catalog\Block\Product\View\Gallery;
use Magento\Catalog\Helper\Image;
use Magento\Framework\Escaper;

/** @var Escaper $escaper */
/** @var Gallery $block */
/** @var ViewModelRegistry $viewModels */

/** @var StoreConfig $storeConfig */
$storeConfig = $viewModels->require(StoreConfig::class);

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

$images = $block->getGalleryImages()->getItems();
$mainImage = current(array_filter($images, [$block, 'isMainImage']));

if (!empty($images) && empty($mainImage)) {
    $mainImage = reset($images);
}

/** @var Image $helper */
$helper = $block->getData('imageHelper');
// Fallback if helper is null (Hyvä case)
if (!$helper) {
    $helper = \Magento\Framework\App\ObjectManager::getInstance()
        ->get(\Magento\Catalog\Helper\Image::class);
}
$mainImageData = $mainImage
    ? $mainImage->getData('small_image_url')
    : ($helper
        ? $helper->getDefaultPlaceholderUrl('image')
        : $block->getViewFileUrl('Magento_Catalog::images/product/placeholder/image.jpg')
    );
$smallWidth = $block->getImageAttribute('product_page_image_small', 'width', 100);
$smallHeight = $block->getImageAttribute('product_page_image_small', 'height', 100);
$mediumWidth = $block->getImageAttribute('product_page_image_medium', 'width', 530);
$mediumHeight = $block->getImageAttribute('product_page_image_medium', 'height', 570);

// Admin Config
$galleryOptionShowRelated = $storeConfig->getStoreConfig('catalog/product_video/show_related') ?? false;
$galleryOptionVideoLoop = $storeConfig->getStoreConfig('catalog/product_video/video_auto_restart') ?? false;

// view.xml Config
$galleryOptionVideoAutoplay = (bool) $block->getVar('gallery/autoplay', 'Magento_Catalog');
$galleryOptionNavVertical = (string) $block->getVar('gallery/navdir', 'Magento_Catalog') === 'vertical';
$galleryOptionAllowfullscreen = (bool) $block->getVar('gallery/allowfullscreen', 'Magento_Catalog');
$galleryOptionLoop = (bool) $block->getVar('gallery/loop', 'Magento_Catalog');
$galleryOptionArrows = $block->getVar('gallery/arrows', 'Magento_Catalog');
$galleryOptionShowCaption = (bool) $block->getVar('gallery/caption', 'Magento_Catalog');
$galleryOptionShowThumbs = (string) $block->getVar('gallery/nav', 'Magento_Catalog') === 'thumbs';
$galleryOptionShowCounter = (string) $block->getVar('gallery/nav', 'Magento_Catalog') === 'counter';
$galleryOptionShowNavArrows = (bool) $block->getVar('gallery/navarrows', 'Magento_Catalog');
$galleryOptionShowNavOverflow = $block->getVar('gallery/navoverflow', 'Magento_Catalog');
$galleryOptionShowFullscreenIcon = (bool) $block->getVar('gallery/fullscreenicon', 'Magento_Catalog');
$galleryOptionShowMagnifier = (bool) $block->getVar('gallery/magnifier/enable', 'Magento_Catalog');
$galleryOptionShowFullscreenBtn = (bool) $block->getVar('gallery/magnifier/fullscreen', 'Magento_Catalog');
$galleryOptionShowMagnifierBtn = $block->getVar('gallery/magnifier/trigger', 'Magento_Catalog') !== "hover";
$galleryOptionMagnifierZoom = (int) $block->getVar('gallery/magnifier/zoom', 'Magento_Catalog');
$galleryOptionAppendOnReceive = (string) $block->getVar('gallery_switch_strategy', 'Magento_ConfigurableProduct') === 'append';

$productName = $block->getProduct()->getName();
$fullActionName = $block->getRequest()->getFullActionName();
$isCartConfigure = $fullActionName === 'checkout_cart_configure';

$wkViewModel = $block->getWkViewModel();
$display = false;
$modelUrl = $iosModelUrl = '';
$imageJson = $block->getGalleryImagesJson();
$imgJsonArray = $wkViewModel->getJsonHelper()->unserialize($imageJson ?? '{}');
$imageCount = count($imgJsonArray);
$params = $block->getRequest()->getParams();
$productId = 0;


/** @var \Magento\Catalog\Model\Product $product */
$product = $block->getProduct();

if (!$product || !$product->getId()) {

    // Cart configure page uses product_id
    $productId = isset($params['product_id'])
        ? (int)$params['product_id']
        : (isset($params['id']) ? (int)$params['id'] : 0);

    if ($productId) {
        $product = $wkViewModel->getProductData($productId);
    }
}

if (!$product || !$product->getId()) {
    return;
}

$productType = $product->getTypeId();
$productId   = (int)$product->getId();
$moduleStatus = $wkViewModel->isModuleEnabled();
$mediaUrl = $wkViewModel->getMediaUrl();

// Get Model Variant Attribute
$defaultVariantAttribute = ($productType == "configurable") ? $product->getModelVariantAttribute() : '';
if ($defaultVariantAttribute == "") {
    $defaultVariantAttribute = "0";
}

// Show Seperate GLB for Configurable Product
$showSeperateGlb = (int)$product->getAllowGlbInChildProducts();
$associatedProducts = ($productType == "configurable") ?
    $wkViewModel->getAssociatedProductModels($product) : [];
$associatedProductsJson = $wkViewModel->getJsonHelper()
    ->serialize($associatedProducts ?? []);

// Get Button Configurations
$btnConfig = $wkViewModel->getARButtonConfig();

// Lighting And Skybox Attributes Configurations
$lightAttrs = $wkViewModel->getLightingAndSkyboxAttributesConfig();

// Staging And Cameras Attributes Configurations
$cameraAttrs = $wkViewModel->getStagingAndCamerasAttributesConfig();

// Image configurations
$imagesConfig = $wkViewModel->getImageAttributesConfig();

// Loading Attributes Configurations
$loading = $wkViewModel->getModelViewerAttributeValue(
    'webar/loading_attribute_settings/loading'
) ?? 'auto';

// Flag to show media gallery images
$canShowOtherImages = $wkViewModel->canShowOtherImages();

// To show or hide gallery
$isGalleryImageShow = true;
if ($moduleStatus && !$canShowOtherImages) {
    $isGalleryImageShow = false;
}

// Flag to show custom image in AR Model thumbnail in media gallery
$showCustomImageInThumbnail = $wkViewModel->canShowCustomImageInThumbnail(
    $imagesConfig["modelThumbnail"]
);

// Check can perform Interpolation Decay
$performInterpolationDecay = 0;
if ($cameraAttrs["autoRotate"] == 0 && $cameraAttrs["interpolationDecay"] != '') {
    $performInterpolationDecay = 1;
    $cameraAttrs["autoRotateDelay"] = 0;
}
// Get AR Model Attributes Json Configurations
$attrConfigJson = $wkViewModel->getAttributeConfigJson(
    $lightAttrs,
    $cameraAttrs,
    $imagesConfig,
    $loading
);

// Set Flag to verify if product has only placeholder image and 3D model
$isPlaceHolderImg = $wkViewModel->getIsPlaceHolderImg($imageCount, $imgJsonArray);

// Set Model Urls
$isArProduct = false;
if ($moduleStatus) {
    $display = true;
    $isArProduct = false;
    $check3dEnabled = $wkViewModel->get3dModelFile($productId);
    if (!empty($check3dEnabled['model_file'])) {
        $isArProduct = true;
        $modelUrl =  $mediaUrl . 'catalog/product/glbmodels/' . $check3dEnabled['model_file'];
    }
    if (!empty($check3dEnabled['ios_file'])) {
        $isArProduct = true;
        $iosModelUrl =  $mediaUrl . 'catalog/product/glbmodels/' . 'ios/' . $check3dEnabled['ios_file'];
    }
    foreach ($associatedProducts as $assocPro) {
        if (strpos($assocPro['modelUrl'], '3DModelNotExists.glb') === false) {
            $isArProduct = true;
        }
    }
}

if (!$canShowOtherImages) {
    $imageCount = 0;
}

if ($showSeperateGlb == 1 && $modelUrl != "") {
    $modelUrl = "";
}

// If modelUrl is empty and showSeperateGlb and module enabled are true, then set modelUrl
if ($modelUrl == "" && $showSeperateGlb == 1 && $display && !empty($associatedProducts)) {
    $modelUrl = $wkViewModel->getDefault3DModelUrl();
    $iosModelUrl = $wkViewModel->getDefault3DIosModelUrl();
}

// If product is configurable and main product don't have images but associated product has images
if ($isPlaceHolderImg && $productType == "configurable") {
    if ($wkViewModel->getIsAssociatedProductHasImgFlag()) {
        $isPlaceHolderImg = 0;
    }
}
$modelThumbnailImg = $mainImageData;
if ($showCustomImageInThumbnail && $imagesConfig["modelThumbnail"] != '') {
    $modelThumbnailImg = $imagesConfig["modelThumbnail"];
}
?>

