<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    layout="1column"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <!-- Try to load all available checkout components. -->
    <update handle="hyva_checkout_components" />
    <!-- Type to load all available form layout elements. -->
    <update handle="hyva_checkout_form_elements" />

    <body>
        <referenceContainer name="page.wrapper"
            htmlClass="page-wrapper min-h-screen bg-teak-stone-light flex flex-col" />
        <referenceContainer
            name="main.content" htmlClass="page-main bg-teak-stone-light flex-grow" />
        <!-- <referenceBlock name="footer-container" remove="true"/> -->
        <referenceBlock name="header-usps" remove="true" />
        <referenceBlock name="authentication-popup" remove="true" />

        <referenceBlock name="script-alpine-js">
            <block name="checkout-usp-csp-block"
                template="Hyva_Checkout::page/js/checkout-usp-csp.phtml" />
            <block name="hyvachild.checkout.customer-comment.csp-js"
                template="Hyva_Checkout::checkout/customer-comment-csp-js.phtml" />
            <block name="hyvachild.checkout.tooltip.csp-js"
                template="Hyva_Checkout::form/field/html/tooltip-csp-js.phtml" />
            <block name="hyvachild.checkout.method-list.csp-js"
                template="Hyva_Checkout::checkout/shipping/method-list-csp-js.phtml" />
            <block name="hyvachild.checkout.terms-conditionlist.csp-js"
                template="Hyva_Checkout::checkout/terms-conditions/list-csp-js.phtml" />
        </referenceBlock>

        <referenceBlock name="footer" remove="true" />

        <referenceContainer name="footer-container">
            <block class="Magento\Theme\Block\Html\Footer"
                name="checkout.footer"
                template="Hyva_Checkout::footer/checkout-footer.phtml" />
        </referenceContainer>

    </body>
</page>