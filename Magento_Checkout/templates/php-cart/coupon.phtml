use Magento\Checkout\Block\Cart\Coupon;
use Magento\Framework\Escaper;

/** @var Coupon $block */
/** @var Escaper $escaper */

$hasCouponCode = (bool) strlen($block->getCouponCode() ?: "");
?>
<script>
    function initCouponForm() {
        return {
            visible: false, // CHANGED: from isExpanded to visible, set to true
            showCouponForm: <?= $hasCouponCode ? 1 : 0 ?>,
            isExpanded: false,
            formData: {
                coupon_code: '<?= $escaper->escapeJs($block->getCouponCode()) ?>',
                remove: '<?= (int) $hasCouponCode ?>'
            },
            init() {
                hyva.getBrowserStorage().removeItem('hyva.showCouponForm');
            },
            // toggleShowCoupon() {
            //     this.isExpanded = !this.isExpanded;
            //     this.$nextTick(() => this.$refs.couponInput.select());
            // },
            toggleVisible() { // CHANGED: from toggleShowCoupon to toggleVisible
                this.visible = !this.visible;
                if (this.visible) {
                    this.$nextTick(() => this.$refs.couponInput && this.$refs.couponInput.select());
                }
            },
            rotateClass() { // ADDED: new method for icon rotation
                return {
                    'transform rotate-180': this.visible
                }
            }
        }
    }
</script>

<div class="flex w-full flex-col border py-3 px-3 rounded-lg mb-2">
    <div x-data="initCouponForm()" class="rounded-md">
        <button id="discountAccordion" type="button" class="flex w-full items-center justify-between gap-2 text-left text-sm text-teak-muted hover:text-teak-green font-garamond"
            aria-controls="discountForm"
            @click="toggleVisible"
            :class="isExpanded ? 'text-onSurfaceStrong' : 'text-onSurface'"
            :aria-expanded="visible">

            <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"></path>
                </svg>
                <?= $escaper->escapeHtml(__('Do you have a discount code?')) ?>
            </span>
            <svg class="w-4 h-4 shrink-0 transition" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true"
                :class="isExpanded ? 'rotate-180' : ''">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
        </button>
        <div x-cloak x-show="visible" id="discountForm" role="region" aria-labelledby="discountAccordion">
            <div class="pt-3">
                <form id="discount-coupon-form"
                    action="<?= $escaper->escapeUrl($block->getUrl('checkout/cart/couponPost')) ?>"
                    method="post"
                    @submit.prevent="hyva.postCart($event.target)">
                    <?= $block->getBlockHtml('formkey') ?>
                    <div class="flex flex-col gap-y-2">
                        <div class="flex-grow">
                            <label for="coupon_code" class="sr-only">
                                <?= $escaper->escapeHtml(__('Enter code')) ?>
                            </label>
                            <input type="text"
                                class="form-input w-full font-normal text-sm text-teak-muted disabled:opacity-75 disabled:bg-gray-100 border border-teakea-light-gray px-2.5 py-1 rounded-lg disabled:border-teakea-light-gray disabled:pointer-events-none shadow-none"
                                id="coupon_code"
                                name="coupon_code"
                                value="<?= $escaper->escapeHtmlAttr($block->getCouponCode()) ?>"
                                placeholder="<?= $escaper->escapeHtmlAttr(__('Enter code')) ?>"
                                x-ref="couponInput"
                                x-model="formData.coupon_code"
                                <?php if ($hasCouponCode): ?>
                                disabled
                                <?php else: ?>
                                required
                                <?php endif; ?> />
                        </div>
                        <div>
                            <?php if (!$hasCouponCode): ?>
                                <button type="submit" class="rounded-lg py-2 px-4 w-full flex justify-center text-center text-sm items-center text-teak-green bg-transparent border border-teak-green hover:text-white hover:bg-teak-green">
                                    <?= $escaper->escapeHtml(__('Apply')) ?>
                                </button>
                            <?php else: ?>
                                <button type="submit" class="rounded-lg py-2 px-4 w-full flex justify-center text-center text-sm items-center text-teakea-red bg-transparent border border-teakea-red hover:text-white hover:bg-teakea-red">
                                    <?= $escaper->escapeHtml(__('Cancel Coupon')) ?>
                                </button>
                            <?php endif; ?>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>