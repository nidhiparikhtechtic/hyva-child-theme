declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Checkout\Block\Onepage\Success;

/** @var Success $block */
/** @var Escaper $escaper */
?>
<div class="checkout-success py-4 text-teakea-black text-base">
    <?php if ($block->getOrderId()): ?>
        <?php if ($block->getCanViewOrder()): ?>
            <p class="mb-2.5">
                <?= $escaper->escapeHtml(
                    __(
                        'Thank you! We have received your order #%1.',
                        sprintf(
                            '<a href="%s" class="order-number"><strong>%s</strong></a>',
                            $escaper->escapeUrl($block->getViewOrderUrl()),
                            $block->getOrderId()
                        )
                    ),
                    ['a', 'strong']
                ) ?>
            </p>
        <?php else: ?>
            <p class="mb-2.5"><?= $escaper->escapeHtml(__('Your order # is: <span>%1</span>.', $block->getOrderId()), ['span']) ?></p>
        <?php endif; ?>
        <p class="mb-2.5">
            <?= $escaper->escapeHtml(
                __('We\'ll email you an order confirmation with details and tracking info.')
            ) ?>
        </p>
    <?php endif; ?>

    <?= $block->getAdditionalInfoHtml() ?>

    <div>
        <a class="relative inline-flex bg-teakea-terracotta text-white text-sm font-semibold items-center py-3.5 px-7 gap-x-2.5 uppercase justify-center rounded-lg" href="<?= $escaper->escapeUrl($block->getContinueUrl()) ?>">
            <span><?= $escaper->escapeHtml(__('Continue Shopping')) ?></span>
        </a>
    </div>
</div>
<!-- PostHog: Identify logged-in & guest customers safely -->
<?php if ($block->getOrderId()): ?>
    <script>
        (function waitForPostHog() {
            if (window.posthog && typeof window.posthog.identify === 'function') {

                <?php if ($block->getCustomerId()): ?>
                    /* Logged-in customer */
                    posthog.identify(
                        '<?= (int) $block->getCustomerId() ?>', {
                            order_id: '<?= $escaper->escapeJs($block->getOrderId()) ?>',
                            customer_type: 'logged_in'
                        }
                    );
                <?php else: ?>
                    /* Guest customer */
                    posthog.identify(
                        '<?= $escaper->escapeJs($block->getOrderId()) ?>', {
                            order_id: '<?= $escaper->escapeJs($block->getOrderId()) ?>',
                            customer_type: 'guest'
                        }
                    );
                <?php endif; ?>

            } else {
                setTimeout(waitForPostHog, 100);
            }
        })();
    </script>
<?php endif; ?>