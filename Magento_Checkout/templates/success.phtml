use Magento\Framework\Escaper;
use Magento\Checkout\Block\Onepage\Success;

/** @var Success $block */
/** @var Escaper $escaper */
?>
<div class="flex flex-col gap-y-1.5 bg-teakea-warm-white rounded-lg shadow-sm border border-teakea-light-gray mb-3 sm:mb-5 p-6 max-w-2xl mx-auto text-center checkout-success">

    <div class="flex items-center justify-center mb-2">
        <div class="flex w-14 h-14 rounded rounded-full items-center justify-center text-white bg-teakea-lime-green">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 29L25 35L37 22" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
    </div>

    <h1 class="text-lg font-extrabold text-teakea-black">
