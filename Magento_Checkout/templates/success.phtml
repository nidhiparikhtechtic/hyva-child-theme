            <?php if ($block->getCanViewOrder()): ?>
                <?= $escaper->escapeHtml(
                    __(
                        'Order #%1',
                        $block->getOrderId()
                    )
                ) ?>
                &middot;
                <a href="<?= $escaper->escapeUrl($block->getViewOrderUrl()) ?>"
                    class="underline hover:text-teakea-black transition-colors">
                    <?= $escaper->escapeHtml(__('View order')) ?>
                </a>
            <?php else: ?>
                <?= $escaper->escapeHtml(__('Order #%1', $block->getOrderId())) ?>
            <?php endif; ?>
            &middot; <?= $escaper->escapeHtml(__('confirmation is on its way')) ?>
        </p>
    <?php endif; ?>

