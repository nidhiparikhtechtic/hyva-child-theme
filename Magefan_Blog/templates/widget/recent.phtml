                                </svg> -->
                            </a>
                        </div>

                    </article>

                <?php endforeach; ?>
            </div>

            <div class="text-center">
                <a href="<?= $block->getUrl('blog') ?>" class="inline-block bg-techtic-terracotta h-[50px] px-11 rounded-lg">
                    <span class="text-sm text-white uppercase font-semibold leading-[48px]">
                        <?= $escaper->escapeHtml(__('View all')) ?>
