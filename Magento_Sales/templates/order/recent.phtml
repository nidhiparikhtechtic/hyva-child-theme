use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Data\Helper\PostHelper;
use Magento\Framework\Escaper;
use Magento\Sales\Block\Order\Recent;
use Magento\Sales\Helper\Reorder;
use Magento\Sales\Model\Order;

// phpcs:disable Magento2.Templates.ThisInTemplate.FoundThis
// phpcs:disable Magento2.Templates.ThisInTemplate.FoundHelper

/** @var Escaper $escaper */
/** @var Recent $block */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
/** @var Order[] $orders */
$orders = $block->getOrders();
$count  = count($orders);

$extraActions = [];
if ($extraActionTitleBlocks = $block->getLayout()->getChildBlocks('order-list-extra-action-titles')) {
    foreach ($extraActionTitleBlocks as $alias => $extraActionTitleBlock) {
        $extraActions[$alias] = $extraActionTitleBlock->toHtml();
    }
    $extraActions = array_filter($extraActions, function ($output, string $alias) use ($block): bool {
        return trim($output) && $block->getLayout()->getChildBlock('order-list-extra-action-buttons', $alias);
    }, ARRAY_FILTER_USE_BOTH);
}

$orderCount = 0;
$totalSpent = 0;
$currencyOrder = null;

$objectManager    = \Magento\Framework\App\ObjectManager::getInstance();
$customerSession  = $objectManager->get(\Magento\Customer\Model\Session::class);
$orderCollection  = $objectManager->create(\Magento\Sales\Model\ResourceModel\Order\Collection::class);

$orderCollection
    ->addFieldToFilter('customer_id', $customerSession->getCustomerId())
    ->addFieldToFilter('state', ['nin' => [
        \Magento\Sales\Model\Order::STATE_CANCELED,
        \Magento\Sales\Model\Order::STATE_CLOSED,
    ]]);

foreach ($orderCollection as $order) {
    $orderCount++;
    $totalSpent += (float) $order->getGrandTotal();

    if ($currencyOrder === null) {
        $currencyOrder = $order;
    }
}

?>

<div class="grid grid-cols-2 gap-2.5 mb-2.5">
    <div class="border border-techtic-light-gray rounded-lg p-3">
        <div class="uppercase text-xs tracking-wider text-teak-muted font-medium mb-2">
            <?= $escaper->escapeHtml(__('Bestellingen')) ?>
        </div>
        <div class="text-xl font-extrabold text-teak-ink">
            <?= $orderCount ?>
        </div>
    </div>

    <div class="border border-techtic-light-gray rounded-lg p-3">
        <div class="uppercase text-xs tracking-wider text-teak-muted font-medium mb-2">
            <?= $escaper->escapeHtml(__('Totaal Besteed')) ?>
        </div>
        <div class="text-xl font-extrabold text-teak-ink">
            <?= $currencyOrder ? $currencyOrder->formatPrice($totalSpent) : '€0,00' ?>
        </div>
    </div>
</div>

<div class="border border-techtic-light-gray rounded-lg p-3 mb-10">
    <div class="text-techtic-terracotta text-sm mb-1">
        <valued-widget layout="rating" size="small" align="left" star-color="yellow" theme="dark"></valued-widget>
    </div>
</div>


<div
    class="block block-dashboard-orders card mt-4 p-0"
    x-data="{ tabIndex: -1 }">
    <div class="block-title order my-4 flex justify-between items-center">
        <h2
            id="recentOrders"
            class="text-base font-bold block uppercase"
            @focus="tabIndex = 0;"
            @blur="tabIndex = -1"
            :tabindex="tabIndex"><?= $escaper->escapeHtml(__('Recent Orders')) ?></h2>
        <?php if ($count > 0): ?>
            <a
                class="action view inline-block text-sm underline"
                href="<?= $escaper->escapeUrl($block->getUrl('sales/order/history')) ?>"
                aria-label="<?= $escaper->escapeHtmlAttr(__('View all orders')) ?>"><?= $escaper->escapeHtml(__('View All')) ?></a>
        <?php endif; ?>
    </div>
    <div class="overflow-x-auto">
        <?= $block->getChildHtml() ?>
        <?php if ($count > 0): ?>
            <div class="space-y-3">
                <?php foreach ($orders as $order): ?>

                    <?php
                    $items = $order->getAllVisibleItems();
                    $firstItem = reset($items);

                    $productName = $firstItem ? $firstItem->getName() : __('Product');
                    $productSku = $firstItem ? $firstItem->getSku() : '';

                    $formData = null;
                    if ($this->helper(Reorder::class)->canReorder($order->getEntityId())) {
                        $formData = json_decode(
                            $this->helper(PostHelper::class)->getPostData(
                                $block->getReorderUrl($order)
                            ),
                            true
                        );
                    }
                    ?>

                    <div class="border border-techtic-light-gray rounded-lg overflow-hidden">

                        <!-- Header -->
                        <div class="flex items-start justify-between p-3 border-b border-techtic-light-gray">
                            <div>
                                <h3 class="text-base font-extrabold text-techtic-deep-green">
                                    <?= $escaper->escapeHtml(__('Order #%1', $order->getRealOrderId())) ?>
                                </h3>
                                <div class="text-sm text-teak-muted mt-1">
                                    <?= $escaper->escapeHtml($block->formatDate($order->getCreatedAt())) ?>
                                </div>
                            </div>

                            <?php
                            $statusKey = strtolower(str_replace(' ', '_', $order->getStatus()));
                            $statusClasses = match ($statusKey) {
                                'pending', 'pending_payment'
                                => 'bg-techtic-lighter-yellow text-techtic-yellow border border-techtic-yellow',
                                'processing'
                                => 'bg-[#e8f4fd] text-[#1565C0] border border-[#1565C0]',
                                'complete', 'closed'
                                => 'bg-[#E8F5E9] text-techtic-deep-green border border-techtic-light-green',
                                'holded'
                                => 'bg-techtic-warm-white text-techtic-dark-brown border border-techtic-yellow',
                                'canceled'
                                => 'bg-[#fdecea] text-techtic-red border border-techtic-red',
                                'fraud', 'payment_review'
                                => 'bg-techtic-lighter-yellow text-techtic-terracotta border border-techtic-terracotta',
                                default
                                => 'bg-techtic-lighter-gray text-techtic-gray border border-techtic-light-gray',
                            };
                            ?>
                            <div class="px-3 py-1 rounded-full text-xs font-semibold <?= $escaper->escapeHtmlAttr($statusClasses) ?>">
                                <?= $escaper->escapeHtml($order->getStatusLabel()) ?>
                            </div>
                        </div>

                        <!-- Product -->
                        <div class="p-4">
                            <?php
                            $product = $firstItem->getProduct();
                            $imageUrl = null;

                            if ($product && $product->getSmallImage() && $product->getSmallImage() !== 'no_selection') {
                                $imageUrl = $block->getUrl('media') . 'catalog/product' . $product->getSmallImage();
                            }
                            ?>

                            <div class="flex items-center gap-4">
                                <div class="w-14 h-14 rounded-lg overflow-hidden border border-techtic-light-gray shrink-0">
                                    <?php if ($imageUrl): ?>
                                        <img
                                            src="<?= $escaper->escapeUrl($imageUrl) ?>"
                                            alt="<?= $escaper->escapeHtmlAttr($productName) ?>"
                                            class="w-14 h-14 object-cover rounded-lg" />
                                    <?php else: ?>
                                        <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                            <span class="text-gray-400 text-xs"></span>
                                        </div>
                                    <?php endif; ?>
                                </div>
                                <div>
                                    <div class="text-sm font-semibold text-teak-dark">
                                        <?= $escaper->escapeHtml($productName) ?>
                                    </div>
                                    <?php if ($productSku): ?>
                                        <div class="text-xs text-teak-muted mt-1">
                                            <?= $escaper->escapeHtml($productSku) ?>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>

                            <?php
                            $comment = null;
                            foreach ($order->getStatusHistories() as $history) {
                                if ($history->getIsCustomerComment()) {
                                    $comment = $history->getComment();
                                }
                            }
                            ?>
                            <?php if ($comment != null): ?>
                                <div class="mt-4 bg-techtic-warm-white border-l-4 border-techtic-deep-green px-4 py-3 rounded-r-lg text-sm">
                                    <b><?= $escaper->escapeHtml(__('Your note')) ?></b>:
                                    <?= $escaper->escapeHtml(__($comment)); ?>
                                </div>
                            <?php endif; ?>

                            <div class="sm:grid grid-cols-2 gap-3 mt-4">
                                <a href="<?= $escaper->escapeUrl($block->getViewUrl($order)) ?>"
                                    class="flex items-center justify-center mb-2 sm:mb-0 p-1.5 md:p-2.5 border border-techtic-deep-green text-techtic-deep-green font-bold rounded-lg hover:-translate-y-[1px]">
                                    <?= $escaper->escapeHtml(__('View')) ?>
                                </a>

                                <?php
                                $canReorder = $this->helper(Reorder::class)->canReorder($order->getEntityId());
                                $formData = json_decode(
                                    $this->helper(PostHelper::class)->getPostData(
                                        $block->getReorderUrl($order)
                                    ),
                                    true
                                )
                                ?>
                                <form action="<?= $escaper->escapeUrl($formData['action']) ?>" method="post">

                                    <?php if ($canReorder): ?>
                                        <?= $block->getBlockHtml('formkey'); ?>
                                        <input type="hidden" name="data" value='<?= /* @noEscape */ json_encode($formData['data']) ?>'>
                                    <?php endif ?>

                                    <button type="submit" class="w-full p-2 md:p-3 bg-techtic-terracotta text-white font-semibold rounded-lg flex justify-center items-center gap-2 hover:-translate-y-[1px]
                                        <?= !$canReorder ? 'opacity-75' : '' ?>"
                                        <?= !$canReorder ? 'disabled' : '' ?>>
                                        <?= $heroicons->refreshHtml('text-gray-300', 20, 20, ['aria-hidden' => 'true']) ?>
                                        <?= $escaper->escapeHtml(__('Reorder')) ?>
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                <?php endforeach; ?>
            </div>
        <?php else: ?>
            <div class="message info empty">
                <span><?= $escaper->escapeHtml(__('You have placed no orders.')) ?></span>
            </div>
        <?php endif; ?>
    </div>
</div>