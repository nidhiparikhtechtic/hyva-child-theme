<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Contact Us</title>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Cms\Block\Block" name="Klant-service-grid" before="-">
                <arguments>
                    <argument name="block_id" xsi:type="string">klant-service-grid</argument>
                </arguments>
            </block>

            <block class="Magento\Cms\Block\Block" name="Contact-block" after="Klant-service-grid">
                <arguments>
                    <argument name="block_id" xsi:type="string">contact-block</argument>
                </arguments>
            </block>

            <block class="Magento\Cms\Block\Block" name="Contact-form" after="Contact-block">
                <arguments>
                    <argument name="block_id" xsi:type="string">contact_form</argument>
                </arguments>
            </block>

            <!-- <block class="Magento\Contact\Block\ContactForm" name="contactForm"
                template="Magento_Contact::form.phtml" cacheable="false">
                <container name="form.additional.info" label="Form Additional Info" />
                <container name="form.additional.after" label="Form Additional After Container" />
                <block name="contactDetails" as="contact.details"
                    template="Magento_Contact::form/contact-details.phtml" />
            </block> -->

            <referenceBlock name="contactForm" remove="true" />
        </referenceContainer>
    </body>
</page>