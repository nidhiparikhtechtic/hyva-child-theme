<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Contact Us</title>
    </head>
    <body>
        <referenceContainer name="content">
            <!-- remove the main page title block -->
            <referenceBlock name="page.main.title" remove="true" />

            <!-- remove the default conatct form -->
            <referenceBlock name="contactForm" remove="true" />

            <block class="Magento\Cms\Block\Block" name="contact-page-banner" before="-">
                <arguments>
                    <argument name="block_id" xsi:type="string">contact_page_banner</argument>
                </arguments>
            </block>

            <block class="Magento\Cms\Block\Block" name="contact-form" after="contact-page-banner">
                <arguments>
                    <argument name="block_id" xsi:type="string">contact_form</argument>
                </arguments>
            </block>

            <block class="Magento\Cms\Block\Block" name="features-banner" after="contact-form">
                <arguments>
                    <argument name="block_id" xsi:type="string">features-banner</argument>
                </arguments>
            </block>

            <block class="Magento\Cms\Block\Block" name="contact-card-with-faq"
                after="features-banner">
                <arguments>
                    <argument name="block_id" xsi:type="string">contact-card-with-faq</argument>
                </arguments>
            </block>

        </referenceContainer>
    </body>
</page>