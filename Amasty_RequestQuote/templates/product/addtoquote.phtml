use Amasty\RequestQuote\Block\Product\Action;
use Amasty\RequestQuoteHyva\ViewModel\QuoteIcons;
use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Framework\Escaper;

/** @var Action $block */
/** @var ViewModelRegistry $viewModels */
/** @var Escaper $escaper */
$quoteIcons = $viewModels->require(QuoteIcons::class);

$buttonClasses  = 'inline-flex gap-x-2.5 items-center justify-center py-3 px-5 btn btn-secondary text-xs md:text-sm w-full mr-auto uppercase';
$buttonClasses .= ' transition-all duration-300 ease-in-out overflow-hidden';
$buttonClasses .= $block->isProductListing() ? ' mt-3' : '';
$buttonClasses .= $block->getLoggedIn()      ? '' : ' amasty-quote-login';
?>

<?php if ($block->isProductListing()): ?>
    <div class="w-full h-0"></div>
<?php endif; ?>

<div>

    <button
        x-data="initAmQuoteButton(
            '<?= $escaper->escapeUrl($block->getAddUrl()); ?>',
            <?=
            /** @noEscape */
            var_export((bool)$block->isProductListing(), true) ?>,
            <?=
            /** @noEscape */
            var_export((bool)$block->getLoggedIn(), true) ?>
        )"
        x-init="initButton($el)"
        @click.prevent="
                submitQuote($el).then((response) => {
                    if (response && response.success) {

                        GTMTracking.push('add_to_cart', {
                            ecommerce: {
                                currency: 'EUR',
                                value: response.total || 0,
                                items: [{
                                    item_name: '<?= $escaper->escapeJs($block->getProduct()->getName()) ?>',
                                    item_id: '<?= $block->getProduct()->getId() ?>',
                                    price: response.price || 0,
                                    quantity: response.qty || 1
                                }]
                            }
                        });

                    }
                }); "
        <?php if (!$block->isProductListing()): ?>
        form="product_addtocart_form"
        <?php endif; ?>
        type="button"
        title="<?= $escaper->escapeHtmlAttr($block->getButtonText()) ?>"
        aria-label="<?= $escaper->escapeHtmlAttr($block->getButtonText()) ?>"
        class="amquote-addto-button <?=
                                    /** @noEscape */
                                    $buttonClasses ?>">

        <!-- Icon: always visible on all devices -->
        <?= $quoteIcons->quoteHtml('w-4 h-4 shrink-0', 25, 25, ['aria-hidden' => 'true']) ?>

        <!-- Label: hidden on mobile always, desktop shows on scroll -->
        <span
            x-transition:enter="transition-all duration-300 ease-in-out"
            x-transition:enter-start="opacity-0 w-0 ml-0"
            x-transition:enter-end="opacity-100 w-auto ml-2"
            x-transition:leave="transition-all duration-300 ease-in-out"
            x-transition:leave-start="opacity-100 w-auto ml-2"
            x-transition:leave-end="opacity-0 w-0 ml-0"
            class="amquote-addto-button-text whitespace-nowrap overflow-hidden">
            <?= $escaper->escapeHtml($block->getButtonText()) ?>
        </span>

        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="#000000" viewBox="0 0 24 24" id="right-arrow" class="icon line">
            <path id="primary" d="M3,12H21m-3,3,3-3L18,9" style="fill: none; stroke: rgb(0, 0, 0); stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.5;" />
        </svg>

    </button>
</div>