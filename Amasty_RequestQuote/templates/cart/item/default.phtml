                                    <li class="leading-tight">

                                        <?php if (isset($formattedOptionValue['full_view'])): ?>
                                            <span class="text-[#6B6B6B]">
                                                <?= $escaper->escapeHtml($formattedOptionValue['full_view']) ?>
