$itemViewModel = $viewModels->require(Item::class);
$sku = $product->getSku();
?>
<div class="cart item">
    <div class="item-info text-left lg:text-right flex flex-col gap-2.5">
        <div class="flex flex-row w-full gap-x-4">

            <div data-th="<?= $escaper->escapeHtml(__('Item')) ?>" class="item flex text-left w-full">
