                                        <?php else: ?>
                                            <span class="text-[#6B6B6B]">
                                                <?= $escaper->escapeHtml($formattedOptionValue['value'], ['span', 'a']) ?>
                                            </span>
                                        <?php endif; ?>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
