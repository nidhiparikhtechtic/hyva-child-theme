<?php

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

$logoBlock = $block->getLayout()->getBlock('logo');
$storeName = $logoBlock ? $logoBlock->getThemeName() : '';

$logoAlt = $escaper->escapeHtmlAttr($storeName ?: 'Teakea');
$logoTitle = $logoAlt . ' - Home';

/** @var \Magento\Framework\View\Element\Template $block */
$socialBlock = $block->getLayout()->createBlock(
    \Amasty\SocialLogin\Block\Social::class,
    'amsociallogin-social-header',
    [
        'data' => [
            'position' => \Amasty\SocialLogin\Model\Source\LoginPosition::POPUP
        ]
    ]
)->setTemplate('Amasty_SocialLogin::social.phtml');

?>
<div x-show="$store.authModal.open"
    x-cloak
    x-data="{
         dragStartY: 0,
         dragCurrentY: 0,
         dragging: false,
         onTouchStart(e) { this.dragStartY = e.touches[0].clientY; this.dragging = true; },
         onTouchMove(e) {
             if (!this.dragging) return;
             this.dragCurrentY = e.touches[0].clientY - this.dragStartY;
             if (this.dragCurrentY > 0) { $refs.sheet.style.transform = `translateY(${this.dragCurrentY}px)`; }
         },
         onTouchEnd() {
             this.dragging = false;
             if (this.dragCurrentY > 100) { $store.authModal.hide(); }
             $refs.sheet.style.transform = '';
             this.dragCurrentY = 0;
         }
     }"
    class="fixed inset-0 z-[200]"
    role="dialog"
    aria-modal="true"
    @keydown.escape.window="$store.authModal.hide()">

    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm touch-none" @click="$store.authModal.hide()"></div>

    <div class="fixed inset-x-0 bottom-0 md:inset-0 md:flex md:items-center md:justify-center md:p-4">

        <div x-ref="sheet"
            @click.outside="$store.authModal.hide()"
            class="relative bg-white w-full rounded-t-2xl
                    md:rounded-xl md:max-w-xl md:w-full
                    lg:max-w-3xl flex flex-col lg:flex-row overflow-hidden
                    max-h-[92vh] lg:max-h-[88vh]
                    shadow-2xl
                    pb-[env(safe-area-inset-bottom)]
                    transition-transform duration-300">

            <!-- Drag handle: mobile only -->
            <div class="md:hidden flex justify-center pt-3 pb-1 cursor-grab shrink-0"
                @touchstart="onTouchStart"
                @touchmove="onTouchMove"
                @touchend="onTouchEnd">
                <div class="w-10 h-1.5 bg-gray-300 rounded-full"></div>
            </div>

            <!-- Brand panel: desktop (lg) only -->
            <div class="hidden lg:flex lg:flex-col
            lg:justify-between
            lg:w-1/3 bg-teakea-deep-green text-white p-8 shrink-0">
                <div class="flex items-center">
                    <a href="<?= $escaper->escapeUrl($block->getUrl('')) ?>" class="flex items-center justify-center">
                        <img src="<?= $escaper->escapeUrl($block->getViewFileUrl('images/logo.svg')) ?>"
                            alt="<?= $logoAlt ?>"
                            title="<?= $logoTitle ?>"
                            class="h-5 w-auto" />
                    </a>
                </div>

                <div>
                    <p class="font-serif italic text-2xl leading-snug mb-2.5">
                        <?= $escaper->escapeHtml(__('Craftsmanship since 2002')) ?>
                    </p>
                    <p class="text-sm text-[#bfe0c9] leading-relaxed">
                        <?= $escaper->escapeHtml(__("We've safely received your details. Choose a password to track your order live and download invoices.")) ?>
                    </p>
                </div>
            </div>

            <!-- Form panel -->
            <div class="relative w-full lg:w-2/3 flex flex-col min-h-0">

                <!-- Tabs -->
                <div class="flex w-full border-b shrink-0 bg-white z-10">
                    <button type="button"
                        @click="$store.authModal.tab = 'login'"
