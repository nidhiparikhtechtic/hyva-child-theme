                                : 'text-gray-400 font-semibold'"
                        class="py-2.5 w-1/2 text-base transition-colors">
                        <?= $escaper->escapeHtml(__('Log in')) ?>
                    </button>
                    <button type="button"
                        @click="$store.authModal.tab = 'register'"
                        :class="$store.authModal.tab === 'register'
                                ? 'border-b-2 border-teakea-terracotta font-bold text-teak-green'
                                : 'text-gray-400 font-semibold'"
                        class="py-2.5 w-1/2 text-base transition-colors">
                        <?= $escaper->escapeHtml(__('Register')) ?>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto py-6 px-7 min-h-0">

                    <div>
                        <?= $socialBlock->toHtml() ?>
