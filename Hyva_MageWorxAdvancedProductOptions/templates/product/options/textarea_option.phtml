                :readonly="isLoading"
                class="product-custom-option form-input w-full" @change="onChangeNonDepField()"
                :id="'options_' + option.option_id + '_text'" :required="option.required"
                form="product_addtocart_form" :name="'options[' + option.option_id + ']'"></textarea>
