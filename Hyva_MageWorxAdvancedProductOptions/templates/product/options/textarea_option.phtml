<script>
(function () {
    if (window.atelierTolbertTextareaCompanion) {
        return;
    }

    window.atelierTolbertTextareaCompanion = function () {
        return {
            visible: false,
            textarea: null,
            observer: null,
            selectors: [
                'textarea.product-custom-option',
                'textarea[id^="options_"][id$="_text"]',
                'textarea[name^="options["]',
                'form#product_addtocart_form textarea',
                '#maatwerk-wensen textarea',
                '.amquote-message-block textarea',
            ],

            init() {
                this.findTextarea();

                // If not found immediately,
                if (!this.textarea) {
                    this.observer = new MutationObserver(() => {
                        this.findTextarea();
                        if (this.textarea) {
                            this.bindEvents();
                            this.observer.disconnect();
                        }
                    });
                    this.observer.observe(document.body, {
                        childList: true,
                        subtree: true
                    });
                } else {
                    this.bindEvents();
                }
            },

            findTextarea() {
                for (const selector of this.selectors) {
                    const field = document.querySelector(selector);
                    if (field) {
                        this.textarea = field;
                        return;
                    }
                }
            },

            bindEvents() {
                if (!this.textarea) {
                    return;
                }
                const updateVisibility = () => {
                    const value = this.textarea.value || '';
                    this.visible = value.trim().length > 0;

                    // analytics event
                    if (this.visible && !this._tracked) {
                        this._tracked = true;
                        window.dataLayer = window.dataLayer || [];
                        window.dataLayer.push({
                            event: 'pdp_atelier_tolbert_custom_note_started'
                        });
                    }
                };

                this.textarea.addEventListener('input', updateVisibility);
                this.textarea.addEventListener('blur', updateVisibility);

                // initial check
                updateVisibility();
            }
        };
    };

})();
</script>