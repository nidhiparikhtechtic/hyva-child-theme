    <script src="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/glide.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var sliders = document.querySelectorAll('.glide');
            sliders.forEach(function(slider) {
                var glide = new Glide(slider, {
                    type: <?= /* @noEscape */ $silderOptions['infinite'] ? "'carousel'" : "'slider'" ?>,
                    rewind: <?= /* @noEscape */ $silderOptions['infinite'] ? 'true' : 'false' ?>,
                    bound: true,
                    focusAt: 0,
                    autoplay: <?= /* @noEscape */ $autoplay ?: 'false' ?>,
                    hoverpause: <?= /* @noEscape */ $hoverpause ? 'true' : 'false' ?>,
                    perView: 5,
                    gap: 20,
                    breakpoints: {
                        2560: {
                            perView: 5,
                            gap: 20
                        },
                        1400: {
                            perView: 4,
                            gap: 15
                        },
                        1024: {
                            perView: 3,
                            gap: 12
                        },
                        768: {
                            perView: 2,
                            gap: 10
                        },
                        480: {
                            perView: 1,
                            gap: 0
                        }
                    }
                });

                glide.on('run', function() {
                    var activeIndex = glide.index,
                        bullets = document.querySelectorAll('.glide__bullet'),
                        currentSlide = slider.querySelectorAll('.glide__slide')[activeIndex],
                        images = currentSlide.querySelectorAll('img');
                    bullets.forEach((bullet, index) => {
                        if (index === activeIndex) {
                            bullet.classList.add('opacity-100');
                            bullet.classList.remove('opacity-30');
                        } else {
                            bullet.classList.remove('opacity-100');
                            bullet.classList.add('opacity-30');
                        }
                    });

                    images.forEach(function(img) {
                        if (img.getAttribute('x-data') && !img.hasAttribute('src')) {
                            img.setAttribute('src', img.getAttribute('data-src'));
                            img.removeAttribute('data-src');
                        }
                    });
                });


                glide.mount();
                // Set first bullet active on initial load
                var bullets = slider.querySelectorAll('.glide__bullet');
                if (bullets.length) {
                    bullets[0].classList.add('opacity-100');
                    bullets[0].classList.remove('opacity-30');
                }
                                /* ── Fix bullets: hide extras beyond scrollable range ── */
                var allBullets = slider.querySelectorAll('.glide__bullet');
                var totalSlides = slider.querySelectorAll('.glide__slide').length;
                var perView = glide.settings.perView;
                var visibleBulletCount = totalSlides - perView + 1;

                allBullets.forEach(function(bullet, index) {
                    if (index >= visibleBulletCount) {
                        bullet.style.display = 'none';
                    }
                });

                /* ── Fix arrows: disable on first/last ── */
                function updateArrows() {
                    var prevBtn = slider.querySelector('.glide__arrow--prev');
                    var nextBtn = slider.querySelector('.glide__arrow--next');
                    var current = glide.index;
                    var total = slider.querySelectorAll('.glide__slide').length;
                    var pv = glide.settings.perView;

                    if (prevBtn) {
                        if (current === 0) {
                            prevBtn.setAttribute('disabled', 'disabled');
                            prevBtn.classList.add('opacity-25', 'pointer-events-none');
                        } else {
                            prevBtn.removeAttribute('disabled');
                            prevBtn.classList.remove('opacity-25', 'pointer-events-none');
                        }
                    }

                    if (nextBtn) {
                        if (current >= total - pv) {
                            nextBtn.setAttribute('disabled', 'disabled');
                            nextBtn.classList.add('opacity-25', 'pointer-events-none');
                        } else {
                            nextBtn.removeAttribute('disabled');
                            nextBtn.classList.remove('opacity-25', 'pointer-events-none');
                        }
                    }
                }

                /* Set initial arrow state */
                updateArrows();

                /* Update on every slide */
                glide.on('run.after', function() {
                    updateArrows();
                });

            });
        });
    </script>

    <style>
        <?php if ($slider->getCustomCss()): ?><?= /* @noEscape */ $slider->getCustomCss() ?><?php endif; ?><?php if (!$silderOptions['arrows']) : ?>.glide__arrows {
            display: none !important;
        }

        <?php endif; ?><?php if (!$silderOptions['dots']) : ?>.glide__bullets {
            display: none !important;
        }

        <?php endif; ?>.glide__arrow:hover {
            opacity: 0.65;
        }
    </style>
<?php endif; ?>