<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\CurrentProduct;
use Magento\Catalog\Model\Product;
use Magento\Framework\Escaper;

/** @var \Magento\Framework\View\Element\Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var CurrentProduct $currentProduct */
$currentProduct = $viewModels->require(CurrentProduct::class);
/** @var Product $product */
$product = $block->getData('product') ?: $currentProduct->get();

if (!$product || !$product->getId()) {
    return;
}

$uspValues = $product->getData('usp_icons');
$deliveryType = (string) $product->getAttributeText('delivery_type');

// Define available USP icons and labels
$usps = [
    'Free delivery NL & BE from €300' => [
        'icon' => 'usp/free_delivery.svg',
        'label' => 'Free delivery NL & BE from €300',
    ],
    '2 year warranty' => [
        'icon' => 'usp/two_year_warranty.svg',
        'label' => '2 year warranty',
    ],
    '30-day return policy' => [
        'icon' => 'usp/thirty_return_policy.svg',
        'label' => '30-day return policy',
    ],
    'FSC certified wood' => [
        'icon' => 'usp/fsc_wood.svg',
        'label' => 'FSC certified wood',
    ],
    'Sustainable wood' => [
        'icon' => 'usp/sustainable_wood.svg',
        'label' => 'Sustainable wood',
    ],
    'Weather-resistant teak' => [
        'icon' => 'usp/weather_resistant_teak.svg',
        'label' => 'Weather-resistant teak',
    ],
    'Suitable for every season' => [
        'icon' => 'usp/all_season_teak.svg',
        'label' => 'Suitable for every season',
    ],
    // HANDMADE TRUST
    'Fully assembled' => [
        'icon'  => 'usp/cabinet.svg',
        'label' => 'Fully assembled',
    ],
    'Easy assembly' => [
        'icon'  => 'usp/level.svg',
        'label' => 'Easy assembly',
    ],
    'Siphon-friendly' => [
        'icon'  => 'usp/pipe.svg',
        'label' => 'Siphon-friendly',
    ],
];

// =========================================================================
// DETERMINE WHICH USPs TO SHOW
// =========================================================================

$selectedOptions = [];

/**
 * HANDMADE → force trust icons
 */
if ($deliveryType === 'Handmade_Production') {
    $selectedOptions = [
        'Fully assembled',
        'Easy assembly',
        'Siphon-friendly',
    ];
}

/**
 * STOCK → use product attribute selection
 */
elseif ($deliveryType === 'Stock_Direct' && $uspValues) {

    // ✅ Fix: handle both array and string cases
    $attributeText = $product->getAttributeText('usp_icons');
    if (is_array($attributeText)) {
        $selectedOptions = $attributeText;
    } elseif (is_string($attributeText)) {
        $selectedOptions = explode(',', $attributeText);
    } else {
        $selectedOptions = [];
    }
}

if (empty($selectedOptions)) {
    return;
}
?>

<?php if (!empty($selectedOptions)): ?>
    <!-- ✅ MOBILE: Horizontal Trust Strip -->
    <div class="lg:hidden border-y border-[#D8D8D8] py-3">
        <div class="flex gap-4 overflow-x-auto whitespace-nowrap px-2 scrollbar-hide">

            <?php foreach ($selectedOptions as $optionLabel): ?>
                <?php if (isset($usps[$optionLabel])): ?>
                    <?php
                    $label = $usps[$optionLabel]['label'] ?? 'USP';
                    $seoText = $label . ' - Teakea';
                    $imageUrl = $block->getViewFileUrl('images/' . $usps[$optionLabel]['icon']);
                    ?>

                    <div class="flex items-center gap-2 min-w-max">

                        <!-- ICON -->
                        <span class="w-6 h-6 flex items-center justify-center bg-teakea-deep-green rounded-full shrink-0">
                            <img
                                src="<?= $escaper->escapeUrl($imageUrl); ?>"
                                alt="<?= $escaper->escapeHtmlAttr($seoText); ?>"
                                title="<?= $escaper->escapeHtmlAttr($seoText); ?>"
                                class="w-[18px] h-[18px]"
                                width="18"
                                height="18"
                                loading="lazy" />
                        </span>

                        <!-- TEXT -->
                        <span class="text-sm text-teakea-dark-gray font-medium whitespace-nowrap">
                            <?= $escaper->escapeHtml(__($label)); ?>
                        </span>

                    </div>

                <?php endif; ?>
            <?php endforeach; ?>

        </div>
    </div>

    <!-- ✅ DESKTOP: Keep existing grid -->
    <div class="hidden lg:grid grid-cols-3 gap-2.5 py-5 lg:border-t border-b border-[#D8D8D8]">
        <?php foreach ($selectedOptions as $optionLabel): ?>
            <?php if (isset($usps[$optionLabel])): ?>
                <?php
                $label = $usps[$optionLabel]['label'] ?? 'USP';
                $seoText = $label . ' - Teakea';
                $imageUrl = $block->getViewFileUrl('images/' . $usps[$optionLabel]['icon']);
                ?>
                <div class="flex flex-col items-center text-sm gap-2.5 font-medium">

                    <span class="w-10 h-10 bg-teakea-deep-green rounded-full flex items-center justify-center">
                        <img
                            src="<?= $escaper->escapeUrl($imageUrl); ?>"
                            alt="<?= $escaper->escapeHtmlAttr($seoText); ?>"
                            title="<?= $escaper->escapeHtmlAttr($seoText); ?>"
                            class="h-8 w-8"
                            width="32"
                            height="32"
                            loading="lazy" />
                    </span>
                    <span class="text-base text-center text-teakea-dark-gray font-medium capitalize">
                        <?= $escaper->escapeHtml(__($usps[$optionLabel]['label'])); ?>
                    </span>

                </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </div>
<?php endif; ?>