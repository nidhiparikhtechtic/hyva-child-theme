/** @var CurrentProduct $currentProduct */
$currentProduct = $viewModels->require(CurrentProduct::class);
/** @var ProductPage $productViewModel */
$productViewModel = $viewModels->require(ProductPage::class);
/** @var ProductPrice $productPriceViewModel */
$productPriceViewModel = $viewModels->require(ProductPrice::class);
/** @var ProductStockItem $stockItemViewModel */
$stockItemViewModel = $viewModels->require(ProductStockItem::class);
/** @var ProductDelivery $deliveryViewModel */
$deliveryViewModel = $viewModels->require(ProductDelivery::class);

/** @var Product $product */
$product = $block->getData('product') ?: $currentProduct->get();

if (!$product || !$product->getId()) {
    return;
}

// Product Data
$productName = $escaper->escapeHtml($product->getName());
$imageUrl = $productViewModel->getImage($product, 'product_page_image_small')->getImageUrl();

// Price Data
$regularPrice = $productPriceViewModel->getPriceValue(RegularPrice::PRICE_CODE, $product);
$finalPrice = $productPriceViewModel->getPriceValue(FinalPrice::PRICE_CODE, $product);
$hasDiscount = $finalPrice < $regularPrice;
$discountPercent = $hasDiscount ? round((($regularPrice - $finalPrice) / $regularPrice) * 100) : 0;

// Stock & Delivery Data
$inStock = (bool)$product->getIsSalable();
$isPreOrder = (bool)$product->getPreOrder();
$deliveryTime = $product->getAttributeText('levertijd') ?: '';
$cjmExpectedDate = $product->getCjm_expecdate() ?: '';

// Check for 1-3 days delivery
$onetothreeDayOptions = ['1_3_werkdagen', '1 tot 3 werkdagen'];
$isOnetothreeDayDelivery = in_array($deliveryTime, $onetothreeDayOptions, true);

// Check for 12 weeks delivery
$twelveWeekOptions = ['12_weken', '12 weken'];
$isTwelveWeeks = in_array($deliveryTime, $twelveWeekOptions, true);

// Get dynamic delivery date and shipping info for 1-3 days delivery
$deliveryDate = '';
$shippingInfo = ['text' => '', 'isFree' => false];
if ($isOnetothreeDayDelivery) {
    $deliveryDate = $deliveryViewModel->getFormattedDeliveryDate();
    $shippingInfo = $deliveryViewModel->getShippingInfo();
}

// Format expected date
$formattedDate = '';
if (!empty($cjmExpectedDate)) {
    try {
        $timestamp = strtotime($cjmExpectedDate);
        if ($timestamp !== false) {
            $formatter = new IntlDateFormatter(
                'nl_NL',
                IntlDateFormatter::LONG,
                IntlDateFormatter::NONE
            );
            $formattedDate = $formatter->format($timestamp);
        }
    } catch (Exception $e) {
        $formattedDate = '';
    }
}

$sku = $escaper->escapeHtml($product->getSku());

// English source string (for CSV translation)
$whatsappBaseText = __('I have a question about the product: %s (SKU: %s)');

// Inject dynamic values AFTER translation
$whatsappMessage = sprintf(
    (string) $whatsappBaseText,
    $productName,
    $sku
);

// Encode for WhatsApp URL
$whatsappMessageEncoded = rawurlencode($whatsappMessage);

// Your WhatsApp number (no +, no spaces)
$whatsappNumber = '31851302543';

$whatsappUrl = 'https://wa.me/' . $whatsappNumber . '?text=' . $whatsappMessageEncoded;
