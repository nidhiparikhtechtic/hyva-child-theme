<script>
    function stickyAddToCartComponent() {
        return {
            showModal: false,
            showErrorModal: false,
            isLoading: false,
            errorMessage: '',
            qty: 1,

            incrementQty() {
                this.qty++;
                this.updateQtyInForm();
            },

            decrementQty() {
                if (this.qty > 1) {
                    this.qty--;
                    this.updateQtyInForm();
                }
            },

            updateQtyInForm() {
                const form = document.getElementById('product_addtocart_form');
                if (form) {
                    const qtyInput = form.querySelector('input[name="qty"]');
                    if (qtyInput) {
                        qtyInput.value = this.qty;
                        // Trigger Alpine event for price updates
                        window.dispatchEvent(new CustomEvent('update-qty-<?= (int)$product->getId() ?>', {
                            detail: this.qty
                        }));
                    }
                }
            },

            async submitForm(event) {
                event?.preventDefault();

                const form = document.getElementById('product_addtocart_form');
                if (!form) {
                    console.error('Add to Cart form not found.');
                    this.showError('Add to Cart form not found.');
                    return;
                }

                // Validate form before submitting
                if (!this.validateForm(form)) {
                    return;
                }

                this.isLoading = true;

                try {
                    const formData = new FormData(form);

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const data = await response.json();

                    // Check for Magento success response
                    if (data.backUrl) {
                        // If there's a backUrl, it usually means there was an error
                        // and Magento wants to redirect back to the product page
                        window.location.href = data.backUrl;
                        return;
                    }

                    // Check for error messages in the response
                    if (data.messages && data.messages.error) {
                        this.showError(data.messages.error.join(', '));
                        return;
                    }

                    // Success - show modal
                    this.showModal = true;

                    // Update mini cart if it exists
                    this.updateMiniCart();
                    // ✅ PostHog: Sticky Add to Cart (SUCCESS only)
                    (function waitForPostHog() {
                        if (window.posthog && typeof window.posthog.capture === 'function') {
                            posthog.capture('add_to_cart', {
                                source: 'pdp_sticky_bar',

                                // Product identifiers (Hyvä-safe)
                                product_id: <?= (int) $product->getId() ?>,
                                sku: '<?= $escaper->escapeJs($product->getSku()) ?>',
                                product_name: '<?= $escaper->escapeJs($product->getName()) ?>',

                                // Pricing
                                price: <?= (float) $finalPrice ?>,
                                currency: 'EUR',

                                // Quantity
                                quantity: this.qty,

                                // Page context
                                page_type: 'pdp',
                                device: window.innerWidth < 768 ? 'mobile' : 'desktop',
                                platform: 'hyva',

                                // Debug / safety
                                event_origin: 'sticky_add_to_cart'
                            });
                        } else {
                            setTimeout(waitForPostHog, 100);
                        }
                    })();


                } catch (error) {
                    console.error('Add to cart error:', error);
                    this.showError('An error occurred while adding the product to cart. Please try again.');
                } finally {
                    this.isLoading = false;
                }
            },

            validateForm(form) {
                // Check if required fields are filled
                const requiredFields = form.querySelectorAll('[required]');
                for (let field of requiredFields) {
                    if (!field.value.trim()) {
                        this.showError('Please fill in all required fields.');
                        return false;
                    }
                }
                return true;
            },

            showError(message) {
                this.errorMessage = message;
                this.showErrorModal = true;
            },

            updateMiniCart() {
                // Update Hyvä mini cart
                if (window.dispatchEvent) {
                    window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                }

                // Fire TriplePixel
                try {
                    const form = document.getElementById('product_addtocart_form');
                    const itemId = form.querySelector('input[name="product"]')?.value || 'unknown';
                    const qty = form.querySelector('input[name="qty"]')?.value || 1;
                    const variantId = form.querySelector('input[name="super_attribute"]')?.value || itemId;

                    if (typeof TriplePixel === 'function') {
                        TriplePixel('AddToCart', {
                            item: itemId,
                            q: parseInt(qty, 10),
                            v: variantId
                        });
                        console.log('✅ TriplePixel fired', {
                            item: itemId,
                            q: qty,
                            v: variantId
                        });
                    } else {
                        console.warn('⚠️ TriplePixel not available yet');
                    }
                } catch (e) {
                    console.error('⚠️ Error firing TriplePixel', e);
                }
            },

            init() {
                // Initialize component
                console.log('Sticky Add to Cart component initialized');
            }
        }
    }
</script>