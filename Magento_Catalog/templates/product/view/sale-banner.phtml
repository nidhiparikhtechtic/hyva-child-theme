<script>
    function productCountdown(initialTime) {
        return {
            timeLeft: initialTime,
            originalTime: initialTime,
            hours: 0,
            minutes: 0,
            seconds: 0,
            progressWidth: 100,

            init() {
                this.updateTime();
                setInterval(() => {
                    if (this.timeLeft > 0) {
                        this.timeLeft--;
                        this.updateTime();
                    } else {
                        this.$el.style.display = 'none';
                    }
                }, 1000);
            },

            updateTime() {
                this.hours = Math.floor(this.timeLeft / 3600);
                this.minutes = Math.floor((this.timeLeft % 3600) / 60);
                this.seconds = this.timeLeft % 60;

                this.progressWidth = this.originalTime > 0 ?
                    (this.timeLeft / this.originalTime) * 100 :
                    0;
            },

            formatTime(value) {
                return value.toString().padStart(2, '0');
            }
        }
    }
</script>