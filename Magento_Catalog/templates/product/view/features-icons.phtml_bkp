<script>
    const CARD_ACTIVE = ['bg-teakea-cream', 'lg:border-r-0']; // card highlight

    function showTab(tabName, el) {

        /* 1 ▸ switch panes */
        document.querySelectorAll('.tab-content').forEach(pane =>
            pane.classList.toggle('hidden', pane.id !== `${tabName}-tab`)
        );

        // 2. Reset all feature cards and span styles
        document.querySelectorAll('.feature-card').forEach(card => {
            card.classList.remove(...CARD_ACTIVE);

            const label = card.querySelector('.card-label');
            if (label) {
                label.classList.remove('font-bold');
                label.classList.add('font-medium');
            }
        });



        // 3. Highlight selected card and change label font
        el.classList.add(...CARD_ACTIVE);

        const activeLabel = el.querySelector('.card-label');
        if (activeLabel) {
            activeLabel.classList.add('font-bold');
            activeLabel.classList.remove('font-medium');
        }
    }

    /* default state on page load */
    document.addEventListener('DOMContentLoaded', () => {
        const firstCard = document.getElementById('card-sustainable');
        if (firstCard) showTab('sustainable', firstCard);
    });
</script>