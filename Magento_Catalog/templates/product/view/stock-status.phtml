$productData['isInStock'] = $stockItemViewModel->isInStock($product);

/**
 * Backorder status
 *
 * 0 = No Backorders
 * 1 = Allow Qty Below 0
 * 2 = Allow Qty Below 0 and Notify Customer
 */
