/**
 * Render stock status section
 */
function renderStockStatus(bool $displayStatus, array $productData, array $dateData, bool $showStatusSection, Escaper $escaper): void
{
    if (!$displayStatus || !$showStatusSection) {
        return;
    }

    $showDateInfo = $dateData['isValid'] && !$dateData['isExpired'];

    // Delivery times >= 2 weeks - these should NOT show "Directly Available"
    $longDeliveryTimes = [
        '2 - 3 weken',
        '2 - 4 weken',
        '3 - 4 weken',
        '3 tot 5 weken',
        '4 - 5 weken',
        '4 tot 6 weken',
        '5 - 6 weken',
        '6 - 7 weken',
        '7 - 8 weken',
        '8 - 9 weken',
        '9 - 10 weken',
        '10 - 11 weken',
        '12 weken'
    ];

    $deliveryTime = $productData['deliveryTime'] ?? '';

    // Show "Directly Available" only if:
    // 1. Product is in stock
    // 2. Delivery time is set
    // 3. Delivery time < 2 weeks (not in $longDeliveryTimes)
    // 4. Date info not shown 
    if (
        $productData['isInStock'] &&
        !empty($deliveryTime) &&
        !$showDateInfo &&
        !in_array($deliveryTime, $longDeliveryTimes, true)
    ): ?>
        <div class="flex gap-x-2.5 items-center" title="<?= __('Availability') ?>">
            <?php renderDirectAvailabilityBadge($productData, $dateData, $escaper); ?>
        </div>

    <?php endif;
}

/**
 * Render tooltip with hover information
 * CRITICAL: Handles empty/null tooltip text gracefully
 */
function renderTooltip(?string $tooltipText, Escaper $escaper): void
{
    // Normalize tooltip text
    $tooltipText = trim((string)$tooltipText);

    // Default fallback text (in Dutch)
    $fallbackText = "This product has been carefully selected and is available for immediate delivery. Comfort, quality, and craftsmanship guaranteed.";

    // Use provided text if not empty, otherwise use fallback
    $displayText = !empty($tooltipText) ? $tooltipText : $fallbackText;

    // Escape the text for safe HTML output
    $escapedText = $escaper->escapeHtml(__($displayText));
    ?>

    <div class="relative group">
        <?php renderTooltipIcon(); ?>
        <div class="stock-tooltip pointer-events-none absolute bottom-[150%] left-[-140px] sm:left-[-100px] lg:left-[-77px] top-auto mt-1 w-44 lg:w-64 xl:w-96 bg-white text-techtic-dark-gray text-xs p-3.5 leading-4 rounded-lg shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-[100]">
            <?= $escapedText ?>
        </div>
    </div>
<?php
}

