    ->get(\Magento\CatalogInventory\Api\StockRegistryInterface::class);
$stockItem = $stockRegistry->getStockItem($product->getId());
$productData['backorders'] = (int)$stockItem->getBackorders();
$productData['isBackorder'] = $productData['backorders'] > 0 && $productData['qty'] <= 0;

// ============================================================================
// DATE CALCULATIONS
// ============================================================================

