    <?php if ($productData['isPreOrder']): ?>
        <div class="flex flex-col sm:flex-row">
            <?php renderPreorderBadge($productData, $dateData, $availabilityFlags, $escaper); ?>
        </div>
    <?php endif; ?>

    <!-- Stock Status Section -->
    <?php if (!$productData['isPreOrder']): ?>
        <?php
        $displayStatus = $block->getParentBlock()->displayProductStockStatus();
        $showDateInfo = $dateData['isValid'] && !$dateData['isExpired'];
        renderStockStatus($displayStatus, $productData, $dateData, !$showDateInfo, $escaper);
        ?>
        <div class="flex items-center gap-1.5">
            <span class="text-xs md:text-sm text-[#646464] font-medium">
                <?= __('Free shipping to the Netherlands and Belgium on orders of €300 or more') ?>
            </span>
        </div>

        <!-- Expected Delivery Information -->
        <div class="delivery_info flex flex-row gap-x-1.5">
            <!-- Standard Delivery Times -->
            <?php if ($productData['deliveryType'] != 'Tower_Living_Stock'): ?>
                <?php if ($productData['isInStock']): ?>
                    <div class="flex flex-col gap-y-1">
                        <!-- Custom Date Availability -->
                        <?php if ($showDateInfo): ?>
                            <div class="deliverytimelabel flex relative w-max gap-x-2.5 items-center">
                                <div class="flex gap-x-1 items-center text-sm font-semibold bg-[#EBEBEB] rounded py-0.5 px-1.5 text-techtic-dark-gray">
                                    <?= __('Available from:') ?> <?= $dateData['visibleDate'] ?>
                                </div>
                                <?php renderTooltip($productData['tooltipText'], $escaper); ?>
                            </div>
                        <?php endif; ?>
                        <?php renderDeliveryTimeContent($productData, $availabilityFlags, $escaper, $deliveryViewModel, $product, $dateData); ?>
                    </div>
                <?php elseif (!$productData['isInStock']): ?>
                    <?php renderRestockAvailabilityBadge($productData, $dateData); ?>
                <?php else: ?>
                    <div class="flex gap-x-2.5 items-center" title="<?= __('Availability') ?>">
                        <span class="<?php echo OUT_OF_STOCK_CLASSES; ?> before:w-3 before:h-3 before:rounded-full before:shrink-0 before:bg-red-500">
                            <?= __('Out of stock') ?>
                        </span>
                    </div>
                <?php endif; ?>

            <?php elseif ($productData['deliveryType'] === 'Tower_Living_Stock'): ?>
                <?php renderTowerLivingStockDelivery($productData, $dateData, $escaper); ?>
            <?php endif; ?>
        </div>

