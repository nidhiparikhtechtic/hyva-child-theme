/**
 * Calculate date-related information
 */
function calculateDateData(?string $cjmExpectedDate): array
{
    $cjmExpectedDate = trim((string)$cjmExpectedDate);
    $isValid = !empty($cjmExpectedDate);
    $timestamp = 0;
    $isExpired = false;
    $visibleDate = null;
    $daysLeft = 0;


    // $timestamp = $isValid ? strtotime($cjmExpectedDate) : 0;
    // $isExpired = $isValid && $timestamp <= (time() + 3 * 24 * 60 * 60);


    if ($isValid) {
        $timestamp = strtotime($cjmExpectedDate);
        $daysLeft = $isValid ? ceil(($timestamp - time()) / 86400) : null;

        if ($timestamp === false) {
            $isValid = false;
            $timestamp = 0;
        } else {
            $isExpired = $timestamp <= time();

            try {
                $formatter = new IntlDateFormatter(
                    'nl_NL',
                    IntlDateFormatter::LONG,
                    IntlDateFormatter::NONE
                );
                $visibleDate = $formatter->format($timestamp);
            } catch (Exception $e) {
                // Fallback to default date format if IntlDateFormatter fails
                $visibleDate = date('j F Y', $timestamp);
            }
        }
    }

    return [
        'isValid' => $isValid,
        'timestamp' => $timestamp,
        'isExpired' => $isExpired,
        'visibleDate' => $visibleDate,
        'daysLeft' => $daysLeft,
    ];
}

/**
 * Determine availability flags based on product attributes
 */
function determineAvailabilityFlags(bool $inStock, ?string $deliveryTime): array
{
    $deliveryTime = trim((string)$deliveryTime);

    $oneDayOptions = ['1_werkdag', '1 werkdag'];
    $onetothreeDayOptions = ['1_3_werkdagen', '1 tot 3 werkdagen'];
    $twelveWeekOptions = ['12_weken', '12 weken'];

    return [
        'isOneDayDelivery' => in_array($deliveryTime, $oneDayOptions, true),
        'isOnetothreeDayDelivery' => in_array($deliveryTime, $onetothreeDayOptions, true),
        'isTwelveWeeks' => in_array($deliveryTime, $twelveWeekOptions, true),
    ];
}

/**
