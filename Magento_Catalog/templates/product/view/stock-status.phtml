/**
 * Calculate ISO week number from a date string (e.g. "2026-07-21" → 30).
 * Returns null when the date string is empty or unparseable.
 */
function calcWeekNumber(?string $cjmExpectedDate): ?int
{
    $cjmExpectedDate = trim((string)$cjmExpectedDate);

    if (empty($cjmExpectedDate)) {
        return null;
    }

    try {

        // Magento datetime format
        $date = new DateTime($cjmExpectedDate);

        // Expired dates should not show
        $today = new DateTime('today');

        if ($date < $today) {
            return null;
        }

        // Client custom week logic
        $startOfYear = new DateTime($date->format('Y') . '-01-01');

        $days = (int)$startOfYear->diff($date)->days + 1;

        return (int)ceil($days / 7);
    } catch (Exception $e) {

        return null;
    }
}

