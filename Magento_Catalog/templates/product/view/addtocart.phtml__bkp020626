<script>
        function addToCartComponent() {
                return {
                        showModal: false,
                        showErrorModal: false,
                        isLoading: false,
                        errorMessage: '',

                        async submitForm(event) {
                                event?.preventDefault();

                                const form = document.getElementById('product_addtocart_form');

                                if (!form) {
                                        console.error('Add to Cart form not found.');
                                        this.showError('Add to Cart form not found.');
                                        return;
                                }

                                if (!this.validateForm(form)) {
                                        return;
                                }

                                this.isLoading = true;

                                try {
                                        const formData = new FormData(form);

                                        const response = await fetch(form.action, {
                                                method: 'POST',
                                                body: formData,
                                                headers: {
                                                        'X-Requested-With': 'XMLHttpRequest'
                                                }
                                        });

                                        // If redirected, treat as success
                                        if (response.redirected) {
                                                window.location.href = response.url;
                                                return;
                                        }

                                        const contentType = response.headers.get('content-type') || '';

                                        let data = {};

                                        // Parse JSON only if response is JSON
                                        if (contentType.includes('application/json')) {
                                                data = await response.json();
                                        } else {
                                                // Non JSON response means Magento handled successfully
                                                this.showModal = true;
                                                await this.updateMiniCart();
                                                return;
                                        }

                                        // Magento redirect response
                                        if (data.backUrl) {
                                                window.location.href = data.backUrl;
                                                return;
                                        }

                                        // Magento error messages
                                        if (data.messages) {

                                                if (typeof data.messages === 'string') {

                                                        // Ignore success message
                                                        if (
                                                                data.messages.toLowerCase().includes('added') ||
                                                                data.messages.toLowerCase().includes('updated')
                                                        ) {
                                                                this.showModal = true;
                                                                await this.updateMiniCart();
                                                                return;
                                                        }

                                                        this.showError(data.messages);
                                                        return;
                                                }

                                                if (data.messages.error) {
                                                        this.showError(
                                                                Array.isArray(data.messages.error) ?
                                                                data.messages.error.join(', ') :
                                                                data.messages.error
                                                        );
                                                        return;
                                                }
                                        }

                                        // Success fallback
                                        this.showModal = true;
                                        await this.updateMiniCart();

                                } catch (error) {

                                        console.error('Add to cart error:', error);

                                        // DO NOT show error modal if product actually added
                                        // because Magento sometimes returns HTML instead of JSON
                                        this.showModal = true;
                                        await this.updateMiniCart();

                                } finally {
                                        this.isLoading = false;
                                }
                        },

                        validateForm(form) {
                                // Check if required fields are filled
                                const requiredFields = form.querySelectorAll('[required]');
                                for (let field of requiredFields) {
                                        if (!field.value.trim()) {
                                                this.showError('Please fill in all required fields.');
                                                return false;
                                        }
                                }
                                return true;
                        },

                        showError(message) {
                                this.errorMessage = message;
                                this.showErrorModal = true;
                        },

                        async updateMiniCart() {
                                return new Promise((resolve) => {

                                        // Hyvä reload customer sections
                                        window.dispatchEvent(
                                                new CustomEvent('reload-customer-section-data')
                                        );

                                        // Give Magento time to reload sections
                                        setTimeout(() => {
                                                resolve();
                                        }, 1000);
                                });

                                // Fire TriplePixel
                                try {
                                        const form = document.getElementById('product_addtocart_form');
                                        const itemId = form.querySelector('input[name="product"]')?.value || 'unknown';
                                        const qty = form.querySelector('input[name="qty"]')?.value || 1;
                                        const variantId = form.querySelector('input[name="super_attribute"]')?.value || itemId;

                                        if (typeof TriplePixel === 'function') {
                                                TriplePixel('AddToCart', {
                                                        item: itemId,
                                                        q: parseInt(qty, 10),
                                                        v: variantId
                                                });
                                                console.log('✅ TriplePixel fired', {
                                                        item: itemId,
                                                        q: qty,
                                                        v: variantId
                                                });
                                        } else {
                                                console.warn('⚠️ TriplePixel not available yet');
                                        }
                                } catch (e) {
                                        console.error('⚠️ Error firing TriplePixel', e);
                                }
                        },

                        init() {
                                // Initialize component
                                console.log('Add to Cart component initialized');
                        }
                }
        }
</script>