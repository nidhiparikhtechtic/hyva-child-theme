<script>
    // Alpine.js Store for Sticky Price
    document.addEventListener('alpine:init', () => {
        Alpine.store('stickyPrice', {
            final: <?= (float)$finalPrice ?>,
            regular: <?= (float)$regularPrice ?>
        });

        window.addEventListener('sticky-price-update', e => {
            const price = typeof e.detail === 'number' ?
                e.detail :
                e.detail?.final;

            if (price !== undefined) {
                Alpine.store('stickyPrice').final = price;
                console.log('✅ Sticky price applied:', price);
            }
        });
    });

    function stickyAddToCartComponent() {
        return {
            showModal: false,
            showErrorModal: false,
            isLoading: false,
            errorMessage: '',
            qty: 1,

            incrementQty() {
                this.qty++;
                this.updateQtyInForm();
            },

            decrementQty() {
                if (this.qty > 1) {
                    this.qty--;
                    this.updateQtyInForm();
                }
            },

            updateQtyInForm() {
                const form = document.getElementById('product_addtocart_form');
                if (form) {
                    const qtyInput = form.querySelector('input[name="qty"]');
                    if (qtyInput) {
                        qtyInput.value = this.qty;
                        // Trigger Alpine event for price updates
                        window.dispatchEvent(new CustomEvent('update-qty-<?= (int)$product->getId() ?>', {
                            detail: this.qty
                        }));
                    }
                }
            },

            async submitForm(event) {
                event?.preventDefault();

                const form = document.getElementById('product_addtocart_form');
                if (!form) {
                    console.error('Add to Cart form not found.');
                    this.showError('Add to Cart form not found.');
                    return;
                }

                // Validate form before submitting
                if (!this.validateForm(form)) {
                    return;
                }

                this.isLoading = true;

                try {
                    const formData = new FormData(form);

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const contentType = response.headers.get('content-type') || '';

                    // Magento cart configure/edit returns HTML instead of JSON
                    if (!contentType.includes('application/json')) {

                        console.log('Non-JSON response detected');

                        this.showModal = true;
                        await this.updateMiniCart();

                        // Close success modal automatically on cart edit
                        if (window.location.pathname.includes('/checkout/cart/configure/')) {

                            setTimeout(() => {
                                // Magento/MageWorx will automatically reload content
                                window.history.back();

                            }, 700);
                        }

                        return;
                    }

                    const data = await response.json();

                    // Handle redirect responses
                    if (data.backUrl) {

                        // Cart configure success flow
                        if (window.location.pathname.includes('/checkout/cart/configure/')) {

                            this.showModal = true;
                            await this.updateMiniCart();

                            setTimeout(() => {
                                window.location.href = '/checkout/cart/';
                            }, 500);

                            return;
                        }

                        window.location.href = data.backUrl;
                        return;
                    }

                    // Real Magento errors only
                    if (data.error) {

                        let message = data.message || 'An error occurred';

                        if (data.messages?.error) {
                            message = Array.isArray(data.messages.error) ?
                                data.messages.error.join(', ') :
                                data.messages.error;
                        }

                        this.showError(message);
                        return;
                    }

                    // SUCCESS
                    this.showModal = true;
                    await this.updateMiniCart();
                    if (typeof gtag === 'function') {
                        gtag('event', 'add_to_cart_sticky');
                    }

                } catch (error) {
                    console.error('Add to cart error:', error);
                    this.showError('An error occurred while adding the product to cart. Please try again.');
                } finally {
                    this.isLoading = false;
                }
            },

            validateForm(form) {
                // Check if required fields are filled
                const requiredFields = form.querySelectorAll('[required]');
                for (let field of requiredFields) {
                    if (!field.value.trim()) {
                        this.showError('Please fill in all required fields.');
                        return false;
                    }
                }
                return true;
            },

            showError(message) {
                this.errorMessage = message;
                this.showErrorModal = true;
            },

            async updateMiniCart() {
                return new Promise((resolve) => {

                    // Hyvä reload customer sections
                    window.dispatchEvent(
                        new CustomEvent('reload-customer-section-data')
                    );

                    // Give Magento time to reload sections
                    setTimeout(() => {
                        resolve();
                    }, 1000);
                });

                // Fire TriplePixel
                try {
                    const form = document.getElementById('product_addtocart_form');
                    const itemId = form.querySelector('input[name="product"]')?.value || 'unknown';
                    const qty = form.querySelector('input[name="qty"]')?.value || 1;
                    const variantId = form.querySelector('input[name="super_attribute"]')?.value || itemId;

                    if (typeof TriplePixel === 'function') {
                        TriplePixel('AddToCart', {
                            item: itemId,
                            q: parseInt(qty, 10),
                            v: variantId
                        });
                        console.log('✅ TriplePixel fired', {
                            item: itemId,
                            q: qty,
                            v: variantId
                        });
                    } else {
                        console.warn('⚠️ TriplePixel not available yet');
                    }
                } catch (e) {
                    console.error('⚠️ Error firing TriplePixel', e);
                }
            },

            init() {
                // Initialize component
                console.log('Sticky Add to Cart component initialized');
            }
        }
    }
</script>