/**
 * Get delivery label configuration based on delivery time
 * Returns: label, color, bgColor, and tooltip for each delivery scenario
 */
function getDeliveryLabelConfig(string $deliveryTime): array
{
    // Define delivery time options for each scenario
    $directDeliveryOptions = ['1_3_werkdagen', '1 tot 3 werkdagen', '1_werkdag', '1 werkdag'];
    $fastDeliveryOptions = ['4_8_werkdagen', '4 tot 8 werkdagen', '4_8_dagen', '4 tot 8 dagen', '1_week', '1 week'];
    $handmadeOptions = ['10_werkdagen', '10 werkdagen'];
    $twoToSixWeeksOptions = ['2_3_weken', '2 tot 3 weken', '3_5_weken', '3 tot 5 weken', '4_6_weken', '4 tot 6 weken', '2 - 3 weken', '3 - 4 weken', '2 - 4 weken', '4 - 5 weken', '5 - 6 weken'];
    $preOrderOptions = ['12_weken', '12 weken', '10_weken', '10 weken', '8 - 9 weken', '9 - 10 weken', '10 - 11 weken'];

    // 🟢 1-3 Working Days - Available immediately(Direct leverbaar)
    if (in_array($deliveryTime, $directDeliveryOptions, true)) {
        return [
            'label' => __('Available immediately'),
            'color' => '#A9E5A1',
            'bgColor' => '#E6FFE2',
            'tooltip' => __('This product is in stock and shipped quickly via our trusted couriers. You will receive a tracking link by email as soon as your order is dispatched. The expected delivery time is %1. You can easily adjust the delivery date through the tracking mail if needed.', $deliveryTime)
        ];
    }

    // 🟡 4-8 Working Days - Available for quick delivery(Snel leverbaar)
    if (in_array($deliveryTime, $fastDeliveryOptions, true)) {
        return [
            'label' => __('Available for quick delivery'),
            'color' => '#FFE9A1',
            'bgColor' => '#FFFBF0',
            'tooltip' => __('This product requires a little more handling and transport care before delivery. Our logistics team carefully prepares it for shipment, which usually takes %1. You will receive tracking details once shipped, including options to adjust your delivery time.', $deliveryTime)
        ];
    }

    // 🔵 10 Working Days - Handmade to order(Handgemaakt op bestelling)
    if (in_array($deliveryTime, $handmadeOptions, true)) {
        return [
            'label' => __('Handmade to order'),
            'color' => '#CDE3FF',
            'bgColor' => '#F0F7FF',
            'tooltip' => __('Your furniture is custom-made by our skilled craftsmen, created especially for you. The production process starts right after you order. This means delivery takes about %1. You will receive clear updates by email, and transport will be handled with extra care and scheduling options to suit you.', $deliveryTime)
        ];
    }

    // 🟠 2-6 Weeks - within 2-6 weeks(binnen 2-6 weken)
    if (in_array($deliveryTime, $twoToSixWeeksOptions, true)) {
        return [
            'label' => __('within 2-6 weeks'),
            'color' => '#FFD8A8',
            'bgColor' => '#FFF5EB',
            'tooltip' => __('This product is currently in production or being shipped from our workshop in Indonesia. The expected delivery time is between 2 and 6 weeks. As soon as it arrives at our warehouse, we will send you an update with a personal delivery schedule. Transparency guaranteed, every step of the way.')
        ];
    }

    // 🔴 8-12 Weeks - Pre-order: delivery within 12 weeks(Pre-order: levering binnen 12 weken)
    if (in_array($deliveryTime, $preOrderOptions, true)) {
        return [
            'label' => __('Pre-order: delivery within 12 weeks'),
            'color' => '#FFC4B3',
            'bgColor' => '#FFF0ED',
            'tooltip' => __('This item is part of our pre-order collection and is being handmade by our craftsmen abroad. Delivery usually takes up to %1. By pre-ordering now, you secure your piece from the next shipment. You will receive regular updates on production and shipping progress.', $deliveryTime)
        ];
    }

    // Fallback - no configuration found
    return [
        'label' => '',
        'color' => '',
        'bgColor' => '',
        'tooltip' => ''
    ];
}

/**
 * Get tooltip for expected in stock date
 * 🟣 Custom date scenario
 */
function getExpectedDateTooltip(string $visibleDate): string
{
    // Try to parse the visible date and add 3 days
    $timestamp = strtotime($visibleDate . ' +3 days');

    // If parsing fails, use a fallback message without the second date
    if ($timestamp === false) {
        return (string) __("This product is expected back in stock on %1. If you order now, you will receive a personal update once it's ready, with flexible delivery scheduling via your tracking email.", $visibleDate);
    }

    $deliveryStartDate = date('j F Y', $timestamp);
    return (string) __("This product is expected back in stock on %1. If you order now, delivery will start around %2. You will receive a personal update once it's ready, with flexible delivery scheduling via your tracking email.", $visibleDate, $deliveryStartDate);
}


// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

/**
 * Calculate date-related information for expected stock dates
 */
function calculateDateData(?string $cjmExpectedDate): array
{
    $isValid = !empty($cjmExpectedDate);
    $timestamp = $isValid ? strtotime($cjmExpectedDate) : 0;
    $isExpired = $isValid && $timestamp <= (time() + 3 * 24 * 60 * 60);

    $visibleDate = null;
    if ($isValid) {
        $formatter = new IntlDateFormatter(
            'nl_NL',
            IntlDateFormatter::LONG,
            IntlDateFormatter::NONE
        );
        $visibleDate = $formatter->format($timestamp);
    }

    return [
        'isValid' => $isValid,
        'timestamp' => $timestamp,
        'isExpired' => $isExpired,
        'visibleDate' => $visibleDate,
    ];
}

