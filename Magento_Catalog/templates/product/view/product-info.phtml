declare(strict_types=1);


use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\ProductAttributes;
use Hyva\Theme\ViewModel\ProductCompare;
use Hyva\Theme\ViewModel\ProductPage;
use Hyva\Theme\ViewModel\Wishlist;
use Magento\Catalog\Model\Product;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var ProductPage $productViewModel */
$productViewModel = $viewModels->require(ProductPage::class);
/** @var ProductAttributes $attributesViewModel */
$attributesViewModel = $viewModels->require(ProductAttributes::class);
/** @var Product $product */
$product = $productViewModel->getProduct();

// Check if product has reviews - multiple fallback methods
$hasReviews = false;
// Method 1: Check rating summary
$reviewsSummary = $product->getRatingSummary();
if ($reviewsSummary && $reviewsSummary->getReviewsCount() > 0):
    $hasReviews = true;
endif;

// Method 2: Check review count attribute
if (!$hasReviews && $product->getReviewsCount() > 0):
    $hasReviews = true;
endif;

// Method 3: Check if review HTML block has content
if (!$hasReviews):
    $reviewHtml = $block->getChildHtml('product.info.review');
    $hasReviews = !empty(trim(strip_tags($reviewHtml)));
endif;

?>

<div class="w-full order-3 md:sticky md:top-0">

    <?php
    $manufacturer = $product->getAttributeText('manufacturer');
    if (!empty($manufacturer) && strtolower($manufacturer) === 'tower living'): ?>
        <div class="bg-teakea-lighter-yellow mb-2.5 py-1.5 px-2.5 rounded-lg text-center">
            <span class="text-sm text-black">
                <?= $escaper->escapeHtml(__('Selected by Teakea · Personally inspected in Tolbert · Delivered quickly to your home')) ?>
            </span>
        </div>
    <?php endif; ?>

    <!-- Product Name -->
    <?= $block->getChildHtml('product.title') ?>

    <!-- Product Review (if has reviews) OR Custom Third Party Review widget (if no reviews) -->
    <?php if ($hasReviews): ?>
        <?= $block->getChildHtml('product.info.review') ?>
    <?php else: ?>
        <!-- Custom Third Party Review widget -->
        <div class="flex mb-5 min-h-[35px] relative z-[1]">
            <valued-widget layout="button" size="medium" align="left" theme="light"></valued-widget>
        </div>
    <?php endif; ?>

    <div class="border border-x border-[#D8D8D8] bg-[#F9F9F9] p-3 rounded-lg mb-2.5 lg:mt-2.5 lg:mb-5">
        <!-- Product Price -->
        <div class="price-top flex items-center mb-1" role="group" aria-label="<?= $escaper->escapeHtmlAttr('Price') ?>">
            <?= $block->getChildHtml("product.info.price") ?>
        </div>

        <!-- Product Klarna Payment logic -->
        <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
            ->setTemplate('Magento_Catalog::product/view/klarna_payment_method.phtml')->toHtml(); ?>

        <!-- Product USP icons -->
        <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
            ->setTemplate('Magento_Catalog::product/view/usp-dynamic-text.phtml')->toHtml(); ?>

        <!-- Product Stock Status -->
        <div class="flex mb-2.5">
            <?= $block->getChildHtml("product.info.stockstatus") ?>
        </div>

        <!-- Product whatsapp block -->
        <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
            ->setTemplate('Magento_Catalog::product/view/whatsapp-block.phtml')->toHtml(); ?>

    </div>

    <!-- Product Payment method icons -->
    <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
        ->setTemplate('Magento_Catalog::product/view/payment_methods.phtml')->toHtml(); ?>

    <!-- Product color swatch attributes -->
    <?= $block->getChildHtml('product.info.form') ?>

    <!-- Product Mageworks other attributes -->
    <div class="flex flex-col sm:flex-row justify-between">
        <?= $block->getChildHtml("alert.urls") ?>
    </div>

    <?php if ($tierPriceBlock = $block->getChildHtml("product.price.tier")): ?>
        <div class="py-4 tier-price-container">
            <?=
            /** @noEscape */
            $tierPriceBlock ?>
        </div>
    <?php endif; ?>

    <!-- Product Add to cart, Qty and wishlist icon -->
    <?php if ($product->isSaleable()): ?>
        <div class="flex flex-col">
            <div class="flex flex-col gap-2.5 justify-between w-auto border-y border-[#D8D8D8] py-4">
                <?php if ($product->isSaleable()): ?>
                    <div class="flex flex-row items-center gap-y-2.5 w-full h-full max-h-10 md:max-h-full xl:max-h-[50px] justify-between">
                        <?= $block->getChildHtml("product.info.quantity") ?>
                    </div>
                <?php endif; ?>
                <div class="flex align-center gap-x-2.5 justify-end">
                    <?= $block->getChildHtml('product.info.addtowishlist'); ?>
                    <?= $block->getChildHtml('product.info.addtocompare'); ?>

                    <?php if ($product->isSaleable()): ?>
                        <?= $block->getChildHtml("product.info.addtocart") ?>
                    <?php endif; ?>
                </div>
            </div>
            <div class="mt-3 text-center">
                <?= $block->getChildHtml('product.info.addquote') ?>
            </div>
        </div>
    <?php endif; ?>

    <!-- Product USP icons -->
    <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
        ->setTemplate('Magento_Catalog::product/view/usp_icons.phtml')->toHtml(); ?>


    <!-- Zoofy sevice button -->
    <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
        ->setTemplate('Magento_Catalog::product/view/zoofy-button.phtml')->toHtml(); ?>

    <!-- Product Quality Infographic Image -->
    <?php echo $block->getLayout()->createBlock(\Magento\Framework\View\Element\Template::class)
        ->setTemplate('Magento_Catalog::product/view/quality-infographic.phtml')->toHtml(); ?>


    <!-- Product Tabs -->
    <?= $block->getChildHtml('product.info.details'); ?>

    <?= $block->getChildHtml("product.info.additional") ?>

    <div id="product-details" class="hidden">
        <?php foreach ($block->getAttributes() as $attributeConfig) {
            $attribute = $attributesViewModel->getAttributeFromLayoutConfig($attributeConfig); ?>
            <?php if ($value = $attribute['value'] ?? null) { ?>
                <div class="flex border-t border-gray-300 py-2 last:mb-6  <?= /* @noEscape */
                                                                            $attribute['value'] ?: "" ?>">
                    <span class="w-1/2 text-left text-gray-700 product-detail-label">
                        <?= $escaper->escapeHtml($attribute['label']) ?>
                    </span>
                    <span class="w-1/2 ml-2 text-left text-gray-900 product-detail-value">
                        <?= $escaper->escapeHtml($value) ?>
                    </span>
                </div>
            <?php } ?>
        <?php } ?>
    </div>
</div>