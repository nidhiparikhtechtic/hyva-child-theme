<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\CurrentProduct;
use Hyva\Theme\ViewModel\ProductPrice;
use Magento\Catalog\Model\Product;
use Magento\Catalog\Pricing\Price\FinalPrice;
use Magento\Catalog\Pricing\Price\RegularPrice;
use Magento\Framework\Escaper;

/** @var \Magento\Framework\View\Element\Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var CurrentProduct $currentProduct */
$currentProduct = $viewModels->require(CurrentProduct::class);

/** @var Product $product */
$product = $block->getData('product') ?: $currentProduct->get();

if (!$product || !$product->getId()) {
    return;
}

/** @var ProductPrice $productPriceViewModel */
$productPriceViewModel = $viewModels->require(ProductPrice::class);

$paymentMethods = [
    'file' => 'images/payment/klarna.png',
    'alt' => 'Klarna'
];

// Check if any payment method is enabled for this product
$hasPaymentEnabled = false;
foreach ($paymentMethods as $attrCode => $data) {
    if ($product->getData($attrCode)) {
        $hasPaymentEnabled = true;
        break;
    }
}

// Check if Klarna is enabled
$klarnaEnabled = $product->getData('enable_klarna');

// Price Data
$regularPrice = $productPriceViewModel->getPriceValue(RegularPrice::PRICE_CODE, $product);
$finalPrice   = $productPriceViewModel->getPriceValue(FinalPrice::PRICE_CODE, $product);

?>

<?php if ($klarnaEnabled): ?>

    <script>
        document.addEventListener('alpine:init', () => {

            // Only register the store once (in case this block renders multiple times)
            if (!Alpine.store('klarnaPrice')) {
                Alpine.store('klarnaPrice', {
                    final: <?= (float)$finalPrice ?>,

                    // Reactive installment getter — always price / 3
                    get installment() {
                        console.log('✅ Klarna price new updated:', (this.final / 3).toFixed(2).replace('.', ','));
                        return '€' + (this.final / 3).toFixed(2).replace('.', ',');
                    }
                });
            }

            // Listen for price changes dispatched by your swatch / option selector
            window.addEventListener('klarna-price-update', (e) => {
                const price = typeof e.detail === 'number' ?
                    e.detail :
                    e.detail?.final;

                if (price !== undefined) {
                    Alpine.store('klarnaPrice').final = price;
                }
            });
        });
    </script>

