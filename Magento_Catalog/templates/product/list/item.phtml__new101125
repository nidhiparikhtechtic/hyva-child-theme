declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Hyva\Theme\ViewModel\BlockJsDependencies;
use Hyva\Theme\ViewModel\ProductCompare;
use Hyva\Theme\ViewModel\ProductListItem;
use Hyva\Theme\ViewModel\ProductPage;
use Hyva\Theme\ViewModel\Wishlist;
use Magento\Catalog\Block\Product\AbstractProduct;
use Magento\Catalog\Helper\Output as CatalogOutputHelper;
use Magento\Catalog\ViewModel\Product\OptionsData as ProductOptionsData;
use Magento\Framework\Escaper;
use Hyva\Theme\ViewModel\ProductStockItem;

// phpcs:disable Magento2.Templates.ThisInTemplate.FoundThis
// phpcs:disable Magento2.Templates.ThisInTemplate.FoundHelper
// phpcs:disable Generic.Files.LineLength.TooLong
// phpcs:disable Generic.WhiteSpace.ScopeIndent

/** @var AbstractProduct $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var ProductPage $productViewModel */
$productViewModel = $viewModels->require(ProductPage::class);

/** @var ProductListItem $productListItemViewModel */
$productListItemViewModel = $viewModels->require(ProductListItem::class);

/** @var CatalogOutputHelper $catalogOutputHelper */
$catalogOutputHelper = $this->helper(CatalogOutputHelper::class);

/** @var ProductCompare $compareViewModel */
$compareViewModel = $viewModels->require(ProductCompare::class);
/** @var Wishlist $wishlistViewModel */
$wishlistViewModel = $viewModels->require(Wishlist::class);

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

$productOptionsViewmodel = $viewModels->require(ProductOptionsData::class);

/** @var Magento\Catalog\Model\Product $product */
if (!($product = $block->getData('product'))) {
    return;
}
$imageDisplayArea = $block->getData('image_display_area');
$templateType = $block->getData('template_type');
$viewMode = $block->getData('view_mode');
$showDescription = $block->getData('show_description');
$showAddToWishlist = $wishlistViewModel->isEnabled();
$showAddToCompare = $compareViewModel->showInProductList();
$viewIsGrid = $viewMode === 'grid';
$productType = $product->getTypeId();
$isProductGroupedOrBundle = $productType === 'bundle' || $productType === "grouped";
$productId = $product->getId();
$options = $productOptionsViewmodel->getOptionsData($product);

$hideDetails = $block->getData('hide_details') ?: false;
$hideRatingSummary = $block->getData('hide_rating_summary') ?: false;

$imageCustomAttributes = $product->getData('image_custom_attributes')
    ?? $block->getData('image_custom_attributes')
    ?? [];
$productName = $catalogOutputHelper->productAttribute($product, $product->getName(), 'name');

// Ensure the required JS is rendered on the page
$viewModels->require(BlockJsDependencies::class)->setBlockTemplateDependency($block, 'Magento_Catalog::product/list/js/price-box.phtml');

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$productRepository = $objectManager->get(\Magento\Catalog\Model\ProductRepository::class);
$product = $productRepository->getById($product->getId(), false, 1);

// ============================================================================
// PRODUCT DATA COLLECTION
// ============================================================================

$inStock = $product->getIsSalable();
$deliveryTime = $product->getAttributeText('levertijd');
$cjmExpectedDate = $product->getCjm_expecdate();
$handmadeEnable = (int)$product->getData('handmade_enable');
$isPreOrder = $product->getPreOrder();

// Get Handmade and USP attributes
$attributeText = $product->getAttributeText('usp_icons');

// Parse USP options
if (is_array($attributeText)) {
    $selectedOptions = $attributeText;
} elseif (is_string($attributeText)) {
    $selectedOptions = array_filter(array_map('trim', explode(',', $attributeText)));
} else {
    $selectedOptions = [];
}

// Badge configuration (matches your design)
$badges = [
    'FSC certified wood' => [
        'label' => 'FSC Wood'
    ],
    '5 year warranty' => [
        'label' => '5-yr warranty'
    ],
    'Free delivery NL & BE' => [
        'label' => 'Free delivery NL & BE'
    ]
];

// Check if we should show badges
$showHandmade = $handmadeEnable;
$showUspBadges = !empty($selectedOptions);
$showAnyBadges = $showHandmade || $showUspBadges;


// Stock Information
/** @var ProductStockItem $stockItemViewModel */
$stockItemViewModel = $viewModels->require(ProductStockItem::class);
$qty = (int)$stockItemViewModel->getQty($product);
$isInStock = $stockItemViewModel->isInStock($product);

// ============================================================================
// DATE CALCULATIONS
// ============================================================================

$isValidDate = !empty($cjmExpectedDate);
$timestamp = $isValidDate ? strtotime($cjmExpectedDate) : 0;
$expiratedDate = $isValidDate && $timestamp <= (time() + 3 * 24 * 60 * 60);

$visibleDate = null;
if ($isValidDate) {
    $formatter = new IntlDateFormatter(
        'nl_NL',
        IntlDateFormatter::LONG,
        IntlDateFormatter::NONE
    );
    $visibleDate = $formatter->format($timestamp);
}

$showDateInfo = $isValidDate && !$expiratedDate;

// ============================================================================
// DELIVERY LABEL CONFIGURATION
// ============================================================================

// Define delivery time categories
$directDeliveryOptions = ['1 tot 3 werkdagen', '1 werkdag'];
$fastDeliveryOptions = ['4 tot 8 werkdagen', '4 tot 8 dagen', '1 week'];
$handmadeOptions = ['10 werkdagen'];
$twoToSixWeeksOptions = ['2 tot 3 weken', '3 tot 5 weken', '4 tot 6 weken', '2 - 3 weken', '3 - 4 weken', '2 - 4 weken', '4 - 5 weken', '5 - 6 weken'];
$preOrderOptions = ['12 weken', '10 weken', '8 - 9 weken', '9 - 10 weken', '10 - 11 weken'];

// Determine label, color, and background for current delivery time
$deliveryLabel = '';
$deliveryColor = '#A9E5A1';
$deliveryBgColor = '#E6FFE2';

if (in_array($deliveryTime, $directDeliveryOptions, true)) {
    $deliveryLabel = __('Available immediately');
    $deliveryColor = '#A9E5A1';
    $deliveryBgColor = '#E6FFE2';
} elseif (in_array($deliveryTime, $fastDeliveryOptions, true)) {
    $deliveryLabel = __('Available for quick delivery');
    $deliveryColor = '#FFE9A1';
    $deliveryBgColor = '#FFFBF0';
} elseif (in_array($deliveryTime, $handmadeOptions, true)) {
    $deliveryLabel = __('Handmade to order');
    $deliveryColor = '#CDE3FF';
    $deliveryBgColor = '#F0F7FF';
} elseif (in_array($deliveryTime, $twoToSixWeeksOptions, true)) {
    $deliveryLabel = __('within 2-6 weeks');
    $deliveryColor = '#FFD8A8';
    $deliveryBgColor = '#FFF5EB';
} elseif (in_array($deliveryTime, $preOrderOptions, true)) {
    $deliveryLabel = __('Pre-order: delivery within 12 weeks');
    $deliveryColor = '#FFC4B3';
    $deliveryBgColor = '#FFF0ED';
}

// Determine if this is a pre-order delivery time
$isPreOrderDelivery = in_array($deliveryTime, $preOrderOptions, true);

?>

<?php if ($product->isSaleable()): ?>
    <form method="post"
        action="<?= $escaper->escapeUrl($productViewModel->getAddToCartUrl($product, ['useUencPlaceholder' => true])) ?>"
        class="item product product-item product_addtocart_form card bg-transparent hover:bg-transparent card-interactive w-full py-0 px-1.5 m-0 <?= $viewIsGrid ? '' : 'md:flex-row' ?>"
        <?php if ($product->getOptions()): ?>
        enctype="multipart/form-data"
        <?php endif; ?>
        <?php foreach ($block->getData('product_data_attributes') as $attribute => $include): ?>
        <?php if ($include): ?>
        <?= $escaper->escapeHtml(sprintf('data-%s', $attribute)); ?>="<?= $escaper->escapeHtmlAttr($product->getData($attribute)); ?>"
        <?php endif; ?>
        <?php endforeach; ?>>
        <?=
        /** @noEscape */
        $block->getBlockHtml('formkey') ?>
        <input type="hidden" name="product" value="<?= (int)$productId ?>" />
        <?php foreach ($options as $optionItem): ?>
            <input type="hidden"
                name="<?= $escaper->escapeHtml($optionItem['name']) ?>"
                value="<?= $escaper->escapeHtml($optionItem['value']) ?>">
        <?php endforeach; ?>
    <?php else: ?>
        <div class="item product product-item card-interactive hover:bg-transparent flex flex-col w-full <?= $viewIsGrid ? '' : 'md:flex-row' ?>"
            <?php foreach ($block->getData('product_data_attributes') as $attribute => $include): ?>
            <?php if ($include): ?>
            <?= $escaper->escapeHtml(sprintf('data-%s', $attribute)); ?>="<?= $escaper->escapeHtmlAttr($product->getData($attribute)); ?>"
            <?php endif; ?>
            <?php endforeach; ?>>
        <?php endif; ?>

        <!-- Product Image -->
        <div class="flex flex-col relative group border rounded-lg border-teakea-light-gray overflow-hidden">
            <a href="<?= $escaper->escapeUrl($product->getProductUrl()) ?>"
                title=""
                class="product photo product-item-photo block <?= $viewIsGrid ? '' : 'md:w-2/6 md:mb-0 md:mr-5 md:shrink-0' ?>"
                tabindex="-1">
                <?= $block->getImage($product, $imageDisplayArea)
                    ->setTemplate('Magento_Catalog::product/list/image.phtml')
                    ->setData('custom_attributes', $imageCustomAttributes)
                    ->setProductId($productId)
                    ->toHtml(); ?>
            </a>

            <!-- Add to Cart Button (on hover) -->
            <div class="flex flex-wrap items-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 absolute bottom-0 w-full <?= $viewIsGrid ? '' : 'md:justify-center' ?>">
                <?php if ($product->isSaleable()): ?>
                    <?php if ($isProductGroupedOrBundle): ?>
                        <a href="<?= $escaper->escapeUrl($product->getProductUrl()) ?>"
                            class="w-auto btn btn-primary justify-center text-sm <?= $viewIsGrid ? 'mr-auto' : 'mr-auto md:mr-0' ?>"
                            title=""
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Configure %1 on the product page', $productName)) ?>">
                            <?= $heroicons->pencilAltHtml('', 24, 24, ['aria-hidden' => 'true']) ?>
                            <span class="ml-2 inline <?= $viewIsGrid ? 'md:ml-0 md:hidden lg:ml-2 lg:inline' : '' ?>">
                                <?= $escaper->escapeHtml(__('Configure')) ?>
                            </span>
                        </a>
                    <?php else: ?>
                        <button class="flex items-center justify-center w-full bg-teakea-lime-green text-white text-sm uppercase py-2.5 px-7 opacity-0 group-hover:opacity-100 transition-opacity duration-300 absolute bottom-0 gap-x-1.5"
                            title=""
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Add to Cart') . ' ' . $productName) ?>"
                            data-addto="cart"
                            aria-hidden="false">
                            <span class="flex select-none text-sm">
                                <?= $escaper->escapeHtml(__('Add to Cart')) ?>
                            </span>
                        </button>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>

        <!-- Product Info -->
        <div class="product-info flex flex-col grow gap-y-2.5 mt-5">
            <!-- Product Name -->
            <div class="flex justify-start text-teakea-dark-gray">
                <a class="product-item-link"
                    aria-hidden="false"
                    href="<?= $escaper->escapeUrl($product->getProductUrl()) ?>"
                    :id="`slide-desc-<?= $escaper->escapeHtmlAttr($product->getId()) ?>-${$id('slider-id')}`">
                    <span class="flex text-sm sm:text-base font-medium line-clamp-2 overflow-hidden"><?= /* @noEscape */ $productName ?></span>
                </a>
            </div>

            <!-- Product Handmade & USP Badges -->
            <?php if ($showAnyBadges): ?>
                <!-- Product Badges Row (Horizontal Pills) -->
                <div class="product-badges-row py-3">
                    <div class="flex flex-wrap items-center gap-2">

                        <?php // Display Handmade Badge 
                        ?>
                        <?php if ($showHandmade): ?>
                            <div class="inline-flex items-center px-2.5 py-1 border border-teakea-light-gray bg-[##F4F4F4] rounded-lg">
                                <span class="text-xs font-medium text-black whitespace-nowrap leading-none">
                                    <?= $escaper->escapeHtml(__('Handmade')) ?>
                                </span>
                            </div>
                        <?php endif; ?>

                        <?php // Display USP Badges first 
                        ?>
                        <?php if ($showUspBadges): ?>
                            <?php foreach ($selectedOptions as $optionLabel): ?>
                                <?php if (isset($badges[$optionLabel])): ?>
                                    <div class="inline-flex items-center px-2.5 py-1 border border-teakea-light-gray bg-[##F4F4F4] rounded-lg">
                                        <span class="text-xs font-medium text-black whitespace-nowrap leading-none">
                                            <?= $escaper->escapeHtml(__($badges[$optionLabel]['label'])) ?>
                                        </span>
                                    </div>
                                <?php endif; ?>
                            <?php endforeach; ?>
                        <?php endif; ?>
                    </div>
                </div>
            <?php endif; ?>

            <!-- Price -->
            <?php if ($isProductGroupedOrBundle): ?>
                <span class="sr-only">
                    <?= $escaper->escapeHtml(__('The price depends on the options chosen on the product page')) ?>
                </span>
            <?php endif; ?>

            <div class="flex items-center font-bold text-base text-teakea-neutral-dark <?= $product->isSaleable() ? 'mt-auto' : 'mt-0' ?>"
                x-data="initPriceBox()"
                x-defer="intersect">
                <?= /* @noEscape */ $productListItemViewModel->getProductPriceHtml($product) ?>
            </div>

            <!-- Low Stock Warning -->
            <?php if ($isInStock && $qty > 0 && $qty < 4): ?>
                <div class="text-teakea-highlight-red font-normal text-xs">
                    <?= $escaper->escapeHtml(__('Only %1 left at this price', $qty)) ?>
                </div>
            <?php endif; ?>

            <!-- Delivery Info -->
            <div class="delivery_info flex flex-row gap-x-1.5">
                <?php if ($showDateInfo): ?>
                    <!-- Custom Date -->
                    <div class="flex gap-x-1 items-center bg-[#DAD0FF] text-teakea-dark-gray text-xs font-normal rounded py-0.5 px-1.5 capitalize">
                        <?= $escaper->escapeHtml(__('Expected in stock on:')) ?> <?= $escaper->escapeHtml($visibleDate) ?>
                    </div>

                <?php elseif ($inStock && $deliveryTime): ?>
                    <?php if (!empty($deliveryLabel)): ?>
                        <!-- Dynamic Label with Background Color -->
                        <div class="flex gap-x-1 items-center text-teakea-dark-gray text-xs font-normal rounded py-0.5 px-1.5 capitalize bg-[<?= $escaper->escapeHtmlAttr($deliveryColor) ?>]">
                            <?php if ($isPreOrderDelivery): ?>
                                <?= $escaper->escapeHtml($deliveryLabel) ?>
                            <?php else: ?>
                                <?= $escaper->escapeHtml(__('Expected shipment:')) ?> <?= $escaper->escapeHtml($deliveryLabel) ?>
                            <?php endif; ?>
                        </div>
                    <?php else: ?>
                        <!-- Fallback: Show Raw Delivery Time -->
                        <div class="flex gap-x-1 items-center text-teakea-dark-gray text-xs font-normal leading-4 capitalize">
                            <?= $escaper->escapeHtml(__('Expected shipment:')) ?> <?= $escaper->escapeHtml($deliveryTime) ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>

        <?php if ($product->isSaleable()): ?>
    </form>
<?php else: ?>
    </div>
<?php endif; ?>