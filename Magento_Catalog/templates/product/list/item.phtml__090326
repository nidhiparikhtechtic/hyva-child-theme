$options = $productOptionsViewmodel->getOptionsData($product);

$hideDetails = $block->getData('hide_details') ?: false;
$hideRatingSummary = $block->getData('hide_rating_summary') ?: false;

$imageCustomAttributes = $product->getData('image_custom_attributes')
    ?? $block->getData('image_custom_attributes')
    ?? [];
$productName = $catalogOutputHelper->productAttribute($product, $product->getName(), 'name');

// Ensure the required JS is rendered on the page
$viewModels->require(BlockJsDependencies::class)->setBlockTemplateDependency($block, 'Magento_Catalog::product/list/js/price-box.phtml');

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$productRepository = $objectManager->get(\Magento\Catalog\Model\ProductRepository::class);
$product = $productRepository->getById($product->getId(), false, 1);

// ============================================================================
// PRODUCT DATA COLLECTION
// ============================================================================

$inStock = $product->getIsSalable();
$deliveryTime = $product->getAttributeText('levertijd');
$cjmExpectedDate = $product->getCjm_expecdate();
$handmadeEnable = (int)$product->getData('handmade_enable');
$isPreOrder = $product->getPreOrder();

// Get Handmade and USP attributes
$attributeText = $product->getAttributeText('usp_icons');

// Parse USP options
if (is_array($attributeText)) {
    $selectedOptions = $attributeText;
} elseif (is_string($attributeText)) {
    $selectedOptions = array_filter(array_map('trim', explode(',', $attributeText)));
} else {
    $selectedOptions = [];
}

// Badge configuration (matches your design)
$badges = [
    'FSC certified wood' => [
        'label' => 'FSC® Teak'
    ],
    '5 year warranty' => [
        'label' => '5 year warranty'
    ],
    'Free delivery NL & BE' => [
        'label' => 'Free delivery NL & BE'
    ],
    'Sustainable wood' => [
        'label' => 'Sustainable wood',
    ]
];

// Check if we should show badges
$showHandmade = $handmadeEnable;
$showUspBadges = !empty($selectedOptions);
$showAnyBadges = $showHandmade || $showUspBadges;

// Stock Information
/** @var ProductStockItem $stockItemViewModel */
$stockItemViewModel = $viewModels->require(ProductStockItem::class);
$qty = (int)$stockItemViewModel->getQty($product);
$isInStock = $stockItemViewModel->isInStock($product);

// ============================================================================
// DATE CALCULATIONS
// ============================================================================

$isValidDate = !empty($cjmExpectedDate);
$timestamp = $isValidDate ? strtotime($cjmExpectedDate) : 0;
$expiratedDate = $isValidDate && $timestamp <= (time() + 3 * 24 * 60 * 60);

$visibleDate = null;
if ($isValidDate) {
    $formatter = new IntlDateFormatter(
        'nl_NL',
        IntlDateFormatter::LONG,
        IntlDateFormatter::NONE
    );
    $visibleDate = $formatter->format($timestamp);
}

$showDateInfo = $isValidDate && !$expiratedDate;

// Define long delivery times (>= 2 weeks)
$longDeliveryTimes = [
    '2 - 3 weken',
    '2 - 4 weken',
    '3 - 4 weken',
    '3 tot 5 weken',
    '4 - 5 weken',
    '4 tot 6 weken',
    '5 - 6 weken',
    '6 - 7 weken',
    '7 - 8 weken',
    '8 - 9 weken',
    '9 - 10 weken',
    '10 - 11 weken',
    '12 weken'
];

$isLongDelivery = in_array($deliveryTime, $longDeliveryTimes, true);

// Availability flags
$isOneDayDelivery = in_array($deliveryTime, ['1_werkdag', '1 werkdag']);
$isOneToThreeDays = in_array($deliveryTime, ['1_3_werkdagen', '1 tot 3 werkdagen']);
$isTwelveWeeks = in_array($deliveryTime, ['12_weken', '12 weken']);

/** @var ProductDelivery $deliveryViewModel */
$deliveryViewModel = $viewModels->require(ProductDelivery::class);
