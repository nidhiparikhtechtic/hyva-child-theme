<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\LucideIcons;
use Hyva\Theme\ViewModel\ProductAttributes as ProductAttributes;
use Magento\Catalog\Model\Product;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var LucideIcons $lucideIcons */
$lucideIcons = $viewModels->require(LucideIcons::class);

/** @var Product $product */
if (! ($product = $block->getData('product'))) {
    return;
}

$productId    = $product->getId();
$productAttribute = $viewModels->require(ProductAttributes::class);
$productName  = $productAttribute->getValue($product, 'name');
?>

<div
    x-data="wishlistButton(<?= (int)$productId ?>)">

    <button
        @click.prevent="toggle()"
        class="transition-colors duration-200 focus:outline-none"
        :class="{
        'text-red-500 hover:text-red-600': isInWishlist(),
        'text-teakea-black hover:text-red-400': !isInWishlist()
    }">

        <!-- filled heart -->
        <svg x-show="isInWishlist()" x-cloak xmlns="http://www.w3.org/2000/svg"
            width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12
5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78
7.78l1.06 1.06L12 21.23l7.78-7.78
1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>

        <!-- outline heart -->
        <svg x-show="!isInWishlist()" x-cloak xmlns="http://www.w3.org/2000/svg"
            width="20" height="20" fill="none" stroke="currentColor"
            stroke-width="2" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78
0L12 5.67l-1.06-1.06a5.5 5.5 0 0
0-7.78 7.78l1.06 1.06L12
21.23l7.78-7.78 1.06-1.06a5.5
5.5 0 0 0 0-7.78z" />
        </svg>

    </button>
</div>
<script>
    function wishlistButton(productId) {

        return {

            productId: productId,

            isInWishlist() {
                return Alpine.store('wishlist').isInWishlist(this.productId);
            },

            async toggle() {

                if (this.isInWishlist()) {
                    await this.remove();
                } else {
                    await this.add();
                }

            },

            async add() {

                Alpine.store('wishlist').add(this.productId);

                const formKey = document.querySelector('input[name="form_key"]').value;

                await fetch(`/wishlist/index/add/product/${this.productId}/`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: new URLSearchParams({
                        form_key: formKey,
                        product: this.productId
                    })
                });

                window.dispatchEvent(new CustomEvent('reload-customer-section-data'));

            },

            async remove() {

                location.href = `/wishlist/index/`;
                // optional: implement ajax remove if needed

            }

        }
    }
</script>