use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\CurrentCategory;
use Hyva\Theme\ViewModel\ProductListItem;
use Hyva\Theme\ViewModel\ProductPage;
use Magento\Catalog\Block\Product\ListProduct;
use Magento\Framework\Escaper;
use Techtic\PlpGridBreaker\ViewModel\GridBreakerRules;

/** @var ListProduct $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var ProductPage $productViewModel */
/** @var CurrentCategory $currentCategoryViewModel */

$productViewModel         = $viewModels->require(ProductPage::class);
$productListItemViewModel = $viewModels->require(ProductListItem::class);
$currentCategoryViewModel = $viewModels->require(CurrentCategory::class);

$gridBreakerViewModel = $viewModels->require(GridBreakerRules::class);

$eagerLoadImagesCount = (int) ($block->getData('eager_load_images_count') ?? 3);
$productCollection = $block->getLoadedProductCollection();

$baseUrl = $block->getBaseUrl(); // Gets base site URL
?>
<?php if (!$productCollection->count()): ?>
    <div class="message info empty">
        <div>
            <?= $escaper->escapeHtml(__('We can\'t find products matching the selection.')) ?>
        </div>
    </div>
<?php else: ?>
    <section id="product-list" aria-label="<?= $escaper->escapeHtmlAttr(__('Product list')) ?>" tabindex="-1">

        <?= $block->getToolbarHtml() ?>
        <?= $block->getAdditionalHtml() ?>
        <?php
        if ($block->getMode() == 'grid') {
            $viewMode         = 'grid';
            $imageDisplayArea = 'category_page_grid';
            $showDescription  = false;
            $templateType     = \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
        } else {
            $viewMode         = 'list';
            $imageDisplayArea = 'category_page_list';
            $showDescription  = true;
            $templateType     = \Magento\Catalog\Block\Product\ReviewRendererInterface::FULL_VIEW;
        }
        /**
         * Position for actions regarding image size changing in vde if needed
         */
        $pos = $block->getPositioned();
        ?>
        <div class="products wrapper mode-<?= /* @noEscape */ $viewMode ?> products-<?= /* @noEscape */ $viewMode ?>">
            <?php
            $gridBreakerRules = $gridBreakerViewModel->getRules();
            ?>
            <ul
                role="list"
                class="mx-auto pt-4 pb-12 grid gap-4 grid-cols-2 <?= /* @noEscape */ $viewMode === 'grid'
                                                                        ? 'lg:grid-cols-3 auto-rows-auto'
                                                                        : '' ?>">
                <?php
                /** @var \Magento\Catalog\Model\Product $product */
                foreach (array_values($productCollection->getItems()) as $i => $product):
                    // Product index starts from 1
                    $index = $i + 1;
                    if ($i < $eagerLoadImagesCount) {
                        $product->setData('image_custom_attributes', ['loading' => 'eager', 'fetchpriority' => 'high']);
                    }
                ?>
                    <li class="flex flex-col product-item" data-product-index="<?= $index ?>">
                        <?= $productListItemViewModel->getItemHtml(
                            $product,
                            $block,
                            $viewMode,
                            $templateType,
                            $imageDisplayArea,
                            $showDescription
                        ); ?>
                    </li>
                    <!-- 🔹 PLP GRID BREAKER INSERTION -->
                    <?php foreach ($gridBreakerRules as $ruleIndex => $rule): ?>
                        <?php
                        $shouldRender = false;
                        $currentPosition = $index; // Desktop position where we're checking

                        // Handle REPEATING RULES (with repeat_every)
                        if (!empty($rule['repeat_every']) && $rule['repeat_every'] > 0) {
                            $desktop = $rule['desktop'];
                            $repeatAfter = $rule['repeat_after'];
                            $repeatEvery = $rule['repeat_every'];

                            // Calculate the first position: desktop + repeat_after
                            $firstPosition = $desktop + $repeatAfter;

                            // First occurrence after repeat_after products from desktop position
                            if ($currentPosition === $firstPosition) {
                                $shouldRender = true;
                            }
                            // Subsequent occurrences: every repeat_every products after the first
                            elseif ($currentPosition > $firstPosition) {
                                $offset = $currentPosition - $firstPosition;
                                if ($offset % $repeatEvery === 0) {
                                    $shouldRender = true;
                                }
                            }
                        }
                        // Handle ONE-TIME RULES (without repeat_every)
                        elseif (!empty($rule['once']) && $rule['desktop'] === $currentPosition) {
                            $shouldRender = true;
                        }
                        ?>

                        <?php if ($shouldRender): ?>
                            <li
                                class="plp-grid-breaker <?= $rule['classes'] ?>"
                                data-rule-index="<?= $ruleIndex ?>"
                                data-desktop-position="<?= $currentPosition ?>"
                                data-mobile-position="<?= $rule['mobile'] ?>"
                                data-block-id="<?= $escaper->escapeHtmlAttr($rule['block']) ?>">
                                <?= $block->getLayout()
                                    ->createBlock(\Magento\Cms\Block\Block::class)
                                    ->setBlockId($rule['block'])
                                    ->toHtml(); ?>
                            </li>
                        <?php endif; ?>
                    <?php endforeach; ?>
                <?php endforeach; ?>
            </ul>
        </div>
        <?= $block->getChildBlock('toolbar')->setIsBottom(true)->toHtml() ?>
        <script>
            (function() {
                // Track which breakers have been repositioned to prevent duplicates
                const repositionedBreakers = new Set();

                function repositionGridBreakers() {
                    const grid = document.querySelector('#product-list ul');
                    if (!grid) return;

                    const isMobile = window.matchMedia('(max-width:1023px)').matches;
                    const breakers = grid.querySelectorAll('.plp-grid-breaker');

                    // Get all product items (not breakers)
                    const productItems = [...grid.children].filter(
                        el => el.classList.contains('product-item')
                    );

                    breakers.forEach(breaker => {
                        // Get the target position based on screen size
                        const desktopPosition = parseInt(breaker.dataset.desktopPosition, 10);
                        const mobilePosition = parseInt(breaker.dataset.mobilePosition, 10);
                        const targetPosition = isMobile ? mobilePosition : desktopPosition;

                        if (!targetPosition) return;

                        // Find the product item at the target position (1-indexed)
                        const targetProduct = productItems[targetPosition - 1];

                        if (targetProduct) {
                            // Check if the breaker is already in the correct position
                            const currentNextProduct = breaker.nextElementSibling;
                            const shouldBeBefore = productItems[targetPosition]; // The product AFTER target position

                            // Only move if not already in correct position
                            if (currentNextProduct !== shouldBeBefore) {
                                // Insert breaker after the target product
                                targetProduct.after(breaker);
                            }
                        }
                    });
                }

                // Initial positioning
                repositionGridBreakers();

                // Debounced resize handler
                let resizeTimer;
                window.addEventListener('resize', () => {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(repositionGridBreakers, 150);
                });
            })();
        </script>

    </section>
<?php endif; ?>