<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="catalog_product_opengraph" />
    <update handle="hyva_product_slider" />
    <body>
        <referenceBlock name="content">
            <block class="Magento\Catalog\Block\Product\View"
                name="product.sale.banner"
                template="Magento_Catalog::product/view/sale-banner.phtml" />
            <block class="Magento\Framework\View\Element\Template"
                name="product.info.fsc.icon"
                template="Magento_Catalog::product/view/fsc-icon.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Techtic\FscCertification\ViewModel\Fsc</argument>
                </arguments>
            </block>

            <block name="gtm.view.item"
                template="Magento_Catalog::product/view/gtm_view_item.phtml" />
        </referenceBlock>

        <move element="product.sale.banner" destination="top.container"
            before="-" />

        <attribute name="itemtype" value="http://schema.org/Product" />
        <attribute name="itemscope" value="itemscope" />

        <!-- <referenceBlock name="product.review.form" remove="true" /> -->
        <referenceContainer name="main.content" htmlClass="py-4 xl:py-7" />

        <move element="content.aside" destination="product.info.main" />
        <move element="homepage-usp" destination="product.info.main" before="product.info.review" />
        <move element="alert.urls" destination="product.info" as="alert.urls" />
        <move element="page.main.title" destination="product.info" as="product.title" />

        <referenceBlock name="product.info.details">
            <block class="Magento\Catalog\Block\Product\View" name="product.info.meubelmakerij"
                group="detailed_info" template="MountainIT_CmsPageToProductDetails::montage.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        MountainIT\CmsPageToProductDetails\ViewModel\CmsPage</argument>
                    <argument translate="true" name="title" xsi:type="string">Meubelmakerij</argument>
                    <argument name="sort_order" xsi:type="string">-10</argument>
                </arguments>
            </block>
            <block
                class="Magento\Framework\View\Element\Template"
                name="product.short.description"
                template="Magento_Catalog::product/view/short_description.phtml"
                group="detailed_info">

                <arguments>
                    <argument name="title" xsi:type="string" translate="true">
                        Snelle informatie
                    </argument>
                    <argument name="sort_order" xsi:type="number">-30</argument>
                </arguments>
            </block>
        </referenceBlock>
        <move element="product.info.details" destination="product.info" />

        <referenceBlock name="product.info.main">
            <block class="Magento\Framework\View\Element\Template"
                name="product.info.fsc.badge"
                template="Magento_Catalog::product/view/fsc-badge.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Techtic\FscCertification\ViewModel\Fsc</argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceBlock name="product.info.main">
            <arguments>
                <argument name="view_model" xsi:type="object">
                    Techtic\Customization\ViewModel\ProductCmsBlockViewModel</argument>
            </arguments>
        </referenceBlock>

    </body>

</page>