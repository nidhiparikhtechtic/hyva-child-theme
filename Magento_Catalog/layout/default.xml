<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="catalog.product.image">
            <arguments>
                <argument name="loading" xsi:type="string">lazy</argument>
                <argument name="decoding" xsi:type="string">async</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="catalog.product.image.small">
            <arguments>
                <argument name="loading" xsi:type="string">lazy</argument>
                <argument name="decoding" xsi:type="string">async</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="catalog.product.image.thumbnail">
            <arguments>
                <argument name="loading" xsi:type="string">lazy</argument>
                <argument name="decoding" xsi:type="string">async</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>