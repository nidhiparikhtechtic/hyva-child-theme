                            const valueSelector = `[name="super_attribute[${attributeId}]"][value="${swatchSet}"]`;
                            const swatch = productItem.querySelector(valueSelector);
                            if (swatch && !swatch.checked) {
                                swatch.dispatchEvent(new Event('change'));
                            }
                        }
                    });
                }
            }
        }
    }
</script>