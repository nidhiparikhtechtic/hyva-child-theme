                if (sameValueFilters.length > 1) {
                    sameValueFilters.forEach(filter => {
                        if (filter !== input) {
                            if (filter.getAttribute('type') === 'radio') {
                                filter.closest('.am-filter').querySelectorAll('input').forEach(option => {
                                    option.checked = false;
