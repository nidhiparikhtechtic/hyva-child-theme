            /**
             *
             * @param key
             * @param value
             * @param page
             * @returns {string}
             */
            getNewClearUrl(key, value, page) {
                const url = new URL(window.location.href);
                const params = new window.URLSearchParams(url.search);

                if (value !== '') {
                    params.set(key, value);
                } else {
                    params.delete(key);
                }

                if (page) {
                    params.set('p', page);
                } else if (key !== 'p') {
                    params.delete('p');
                }

                url.search = params;

                return window.decodeURIComponent(url.toString());
            },

