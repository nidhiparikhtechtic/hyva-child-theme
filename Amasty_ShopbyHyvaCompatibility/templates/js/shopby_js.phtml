            getClearUrlParams(url, data) {
                let params = '';

                url = url.replace('#', '');

                data.forEach((param, index) => {
                    if (index > 0) {
                        params += '&';
                    }

                    params += `${param.name}=${param.value}`;
                });

                url += (url.includes('?') ? '&' : '?');

                return `${url}${params}`;
