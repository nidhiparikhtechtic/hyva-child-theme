                    x-data="{
    current: 0,
    visible: 4,
    itemWidth: 220,
    get total() {
        return $el.querySelectorAll('.amrelated-pack-item-wrapper').length
    },
    get maxSlide() {
        return Math.max(0, this.total - this.visible)
    },
    next() {
        if (this.current < this.maxSlide) this.current++
        this.syncToPack()
    },
    prev() {
        if (this.current > 0) this.current--
        this.syncToPack()
    },
    syncToPack() {
        const packEl = $el.closest('[data-amrelated-js=\'pack-wrapper\']')
        if (packEl) {
            const outerScope = Alpine.$data(packEl.closest('[x-data]'))
            if (outerScope && outerScope.packs) {
                const packId = packEl.dataset.packId
                const pack = outerScope.packs.find(p => String(p.bundle.pack_id) === String(packId))
                if (pack) {
                    pack.sliderCurrent = this.current
                    pack.sliderMax = this.maxSlide
                }
            }
        }
    },
    init() {
        this.$nextTick(() => {
            this.syncToPack()
        })
        window.addEventListener('bundle-slider-prev', () => this.prev())
        window.addEventListener('bundle-slider-next', () => this.next())
    }
}"
