use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Hyva\Theme\ViewModel\Navigation;
use Magento\Cms\Block\Block as CmsBlock;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Navigation $viewModelNavigation */
$viewModelNavigation = $viewModels->require(Navigation::class);

/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

$uniqueId = '_' . uniqid();

// Order is important here: 1. build the menu data, 2. then set the cache tags from the view model identities
$menuItems = $viewModelNavigation->getNavigation(4);
$block->setData('cache_tags', $viewModelNavigation->getIdentities());

?>

<div x-data="initMenuDesktop<?= $escaper->escapeHtml($uniqueId) ?>()"
    class="z-20 order-2 sm:order-1 lg:order-2 navigation hidden lg:flex">
    <!-- desktop -->


    <div
        x-data="{hideNav:false}"
        @load.window="setActiveMenu($root)"
        x-init="document.addEventListener('hideNav',event=>{hideNav = event.detail})"
        class="flex justify-center items-center w-full ">
        <nav

            class="flex flex-wrap"
            x-cloak
            :class="hideNav ? 'opacity-0' : 'opacity-100'">

            <ul class="flex w-full justify-center gap-x-5" role="menu" aria-label="Main menu">
                <li class="flex items-center" role="none">
                    <a role="menuitem" class="flex w-full level-0 text-neutral-950 font-medium text-sm not-italic leading-4"
                        href="<?php echo $block->getUrl(''); ?>"><?php echo __('Home'); ?></a>
                </li>
                <?php foreach ($menuItems as $index => $itemLevel1): ?>
                    <?php $singleItems = []; ?>
                    <li
                        class="level-0 flex items-center group"
                        role="none"
                        @mouseover.stop="hoverTopPosition = $event.currentTarget.offsetTop + $event.currentTarget.getBoundingClientRect().height">
                        <a href="<?= $escaper->escapeUrl($itemLevel1['url']) ?>"
                            role="menuitem"
                            @focus="hoverTopPosition = $event.currentTarget.parentNode.offsetTop + $event.currentTarget.parentNode.getBoundingClientRect().height"
                            title="<?= $escaper->escapeHtmlAttr($itemLevel1['name']) ?>"
                            class="flex items-center w-full level-0 text-neutral-950 font-medium text-sm not-italic leading-4 gap-x-1">
                            <span><?= $escaper->escapeHtml($itemLevel1['name']) ?></span>
                            <?php if (!empty($itemLevel1['childData'])): ?>
                                <span class="inline items-center">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M6 9L12 15L18 9" stroke="black" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            <?php endif; ?>
                        </a>
                        <?php if (!empty($itemLevel1['childData'])): ?>
                            <div
                                class="absolute left-0 top-full z-10 -mt-3 w-full bg-white opacity-0 transition-opacity ease-out pointer-events-none group-hover:opacity-100 focus-within:opacity-100 group-hover:pointer-events-auto"
                                :style="`margin-top: 0; top: ${hoverTopPosition}px;`">
                                <div class="flex justify-between">
                                    <?php
                                    $catIdLvl1 = ($pos = strrpos($itemLevel1['id'], '-')) !== false
                                        ? substr($itemLevel1['id'], $pos + 1)
                                        : 0;
                                    $cmsBlockHtml = $catIdLvl1
                                        ? $this->getLayout()
                                        ->createBlock(CmsBlock::class)
                                        ->setBlockId('megamenu_block_left_cat' . $catIdLvl1)
                                        ->toHtml()
                                        : '';

                                    if (!empty($cmsBlockHtml)): ?>
                                        <div class="max-w-xs 2xl:block">
                                            <?=
                                            /** @noEscape */
                                            $cmsBlockHtml ?>
                                        </div>
                                    <?php endif; ?>
                                    <div class="mx-auto">
                                        <ul role="menu" aria-label="Submenu" class="grid flex-1 grid-cols-5 lg:grid-cols-6 gap-y-1 gap-x-5 px-4 py-8">
                                            <?php foreach ($itemLevel1['childData'] as $itemLevel2): ?>
                                                <?php if (empty($itemLevel2['childData'])): ?>
                                                    <?php $singleItems[] = $itemLevel2 ?>
                                                    <?php continue; ?>
                                                <?php endif; ?>


                                                <li role="menuitem" class="level-1 overflow-hidden">

                                                    <a href="<?= $escaper->escapeUrl($itemLevel2['url']) ?>"
                                                        title="<?= $escaper->escapeHtmlAttr($itemLevel2['name']) ?>"

                                                        class="level-1 p-1 block text-base font-semibold leading-loose hover:underline">

                                                        <img
                                                            class="rounded-full rounded-bl-none w-full h-[70px] object-cover mb-5"
                                                            height="70" width="212" fetchpriority="low"
                                                            alt="<?= $escaper->escapeHtmlAttr($itemLevel2['name']) ?>"
                                                            src="<?php echo ($itemLevel2['image']) ?>">

                                                        <span class="text-xl font-bold break-all">
                                                            <?= $escaper->escapeHtml($itemLevel2['name']) ?>
                                                        </span>
                                                    </a>

                                                    <ul role="menu" aria-label="Submenu" class="z-10 w-full mt-5">
                                                        <?php foreach ($itemLevel2['childData'] as $itemLevel3): ?>
                                                            <li role="none" class="level-2 flex align-middle">
                                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                                    <path d="M6 9L12 15L18 9" stroke="black" stroke-linecap="round" stroke-linejoin="round" />
                                                                </svg>
                                                                <a href="<?= $escaper->escapeUrl($itemLevel3['url']) ?>"
                                                                    title="<?= $escaper->escapeHtmlAttr($itemLevel3['name']) ?>"
                                                                    class="level-2 pb-1 block text-base hover:underline break-words"
                                                                    role="menuitem">
                                                                    <?= $escaper->escapeHtml($itemLevel3['name']) ?>
                                                                </a>
                                                            </li>
                                                        <?php endforeach; ?>
                                                    </ul>

                                                </li>
                                            <?php endforeach; ?>
                                            <?php if ($singleItems): ?>
                                                <li role="none" class="level-1 overflow-hidden min-w-0 lg:min-w-48">
                                                    <?php foreach ($singleItems as $item): ?>
                                                        <a href="<?= $escaper->escapeUrl($item['url']) ?>"
                                                            role="menuitem"
                                                            title="<?= $escaper->escapeHtmlAttr($item['name']) ?>"
                                                            class="level-1 p-1 block text-base font-semibold leading-loose hover:underline">
                                                            <?= $escaper->escapeHtml($item['name']) ?>
                                                        </a>
                                                    <?php endforeach; ?>
                                                </li>
                                            <?php endif; ?>

                                        </ul>
                                    </div>
                                    <?php
                                    $cmsBlockHtml = $catIdLvl1
                                        ? $this->getLayout()
                                        ->createBlock(CmsBlock::class)
                                        ->setBlockId('megamenu_block_right_cat' . $catIdLvl1)
                                        ->toHtml()
                                        : '';

                                    if (!empty($cmsBlockHtml)): ?>
                                        <div class="max-w-xs 2xl:block">
                                            <?=
                                            /** @noEscape */
                                            $cmsBlockHtml ?>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>


                <?php
                echo $this->getLayout()
                    ->createBlock('Magento\Cms\Block\Block')
                    ->setBlockId('nav-items-teakea')
                    ->toHtml();
                ?>
            </ul>
        </nav>
    </div>

</div>
<script>
    'use strict';

    const initMenuDesktop<?= $escaper->escapeHtml($uniqueId) ?> = () => {
        return {
            hoverTopPosition: '100%',
            setActiveMenu(menuNode) {
                Array.from(menuNode.querySelectorAll('a')).filter(link => {
                    return link.href === window.location.href.split('?')[0];
                }).map(item => {
                    if (!item.classList.contains('level-0')) {
                        item.classList.add('underline');
                    }
                    item.closest('div.level-0') &&
                        item.closest('div.level-0').classList.add('border-secondary');
                });
            }
        }
    }
</script>