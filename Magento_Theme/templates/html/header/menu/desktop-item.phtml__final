declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

/** @var string[] $menu */
$item = $block->getData('item');
$level = $block->getData('level');
$menuId = str_replace('-', '_', $item['id']);
?>

<?php if (!empty($item['childData'])): ?>
    <li
        class="level-<?= $level ?>"
        x-data="{ subMenuOpen<?= $menuId ?>: false }"
        @click.outside="subMenuOpen<?= $menuId ?> = false">
        <button
            type="button"
            class="group w-full flex justify-between items-center gap-1 py-3.5 px-8 font-medium text-base text-black
                aria-expanded:text-black aria-expanded:bg-[#FFECC7] data-[has-current]:font-medium"
            x-ref="childmenuToggle<?= $menuId ?>"
            @click="subMenuOpen<?= $menuId ?> = !subMenuOpen<?= $menuId ?>;
                $nextTick(() => {
                    $refs.childmenuViewAll<?= $menuId ?>.focus();
                    $refs.childmenuWrapper<?= $menuId ?>.scrollIntoView({
                        behavior: 'smooth',
                        block: 'nearest',
                        inline: 'end'
                    });
                });"
            aria-expanded="false"
            :aria-expanded="subMenuOpen<?= $menuId ?>"
            aria-controls="<?= $escaper->escapeHtml($item['id']) ?>-desktop-menu-panel">
            <?= $escaper->escapeHtml($item['name']) ?>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M9 18L15 12L9 6" stroke="black" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </button>
        <ul
            id="<?= $escaper->escapeHtml($item['id']) ?>-desktop-menu-panel"
            class="grid grid-cols-1 md:grid-cols-2 absolute top-1 left-12 w-1/2 translate-x-72 bg-teakea-cream"
            x-show="subMenuOpen<?= $menuId ?>"
            x-ref="childmenuWrapper<?= $menuId ?>"
            @keydown.escape.stop="subMenuOpen<?= $menuId ?> = false;
                $refs.childmenuToggle<?= $menuId ?>.focus();">
            <?php foreach ($item['childData'] as $subMenu): ?>
                <?= $block->getLayout()->getBlock('topmenu_desktop_item')
                    ->setItem($subMenu)
                    ->setLevel($level + 1)
                    ->toHtml() ?>
            <?php endforeach; ?>
            <li class="col-span-2 text-center py-3.5 border-t border-[#00000033]">
                <a
                    href="<?= $escaper->escapeUrl($item['url']) ?>"
                    class="flex py-3 px-2 text-center justify-center uppercase aria-[current=page]:font-semibold border border-black font-semibold text-sm text-[#1e1e1e]"
                    x-ref="childmenuViewAll<?= $menuId ?>"><?= $escaper->escapeHtml(__('See all %1', $item['name'])) ?></a>
            </li>
        </ul>
    </li>
<?php else: ?>
    <li class="level-<?= $level ?> list-disc p-3.5">
        <a
            href="<?= $escaper->escapeUrl($item['url']) ?>"
            class="level-<?= $level ?> flex text-black text-base aria-[current=page]:text-teakea-red"><?= $escaper->escapeHtml($item['name']) ?></a>
    </li>
<?php endif; ?>