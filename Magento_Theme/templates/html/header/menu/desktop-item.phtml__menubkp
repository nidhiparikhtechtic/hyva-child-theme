declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsSolid;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;
use Techtic\Customization\ViewModel\CategoryFavicon;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HeroiconsSolid $heroiconsSolid */
$heroiconsSolid = $viewModels->require(HeroiconsSolid::class);

/** @var array $item */
$item   = $block->getData('item');
$level  = (int) $block->getData('level');
$menuId = str_replace('-', '_', (string) $item['id']);

$categoryFaviconVm = $viewModels->require(CategoryFavicon::class);
$categoryFaviconUrl = null;

if (!empty($item['id']) && str_starts_with($item['id'], 'category-node-')) {
    $categoryId = (int) str_replace('category-node-', '', $item['id']);
    $categoryFaviconUrl = $categoryFaviconVm->getFaviconUrlByCategoryId($categoryId);
}
?>

<?php if (!empty($item['childData'])): ?>
    <li
        class="level-<?= $level ?>"
        x-data="{ subMenuOpen<?= $menuId ?>: false }"
        @click.outside="subMenuOpen<?= $menuId ?> = false">
        <button
            type="button"
            class="group w-full flex justify-between items-center py-3.5 px-8 font-medium text-base text-black
                aria-expanded:text-terracotta aria-expanded:bg-[#FFECC7] data-[has-current]:font-medium"
            x-ref="childmenuToggle<?= $menuId ?>"
            @click="subMenuOpen<?= $menuId ?> = !subMenuOpen<?= $menuId ?>;
                $nextTick(() => {
                    $refs.childmenuViewAll<?= $menuId ?>.focus();
                    $refs.childmenuWrapper<?= $menuId ?>.scrollIntoView({
                        behavior: 'smooth',
                        block: 'nearest',
                        inline: 'end'
                    });
                });"
            aria-expanded="false"
            :aria-expanded="subMenuOpen<?= $menuId ?>"
            aria-controls="<?= $escaper->escapeHtmlAttr($item['id']) ?>-desktop-menu-panel">

            <div class="flex items-center gap-x-2.5">
                <?php if ($categoryFaviconUrl): ?>
                    <img src="<?= $escaper->escapeUrl($categoryFaviconUrl) ?>"
                        alt="<?= $escaper->escapeHtmlAttr($item['name']) ?>"
                        class="category-favicon" />
                <?php endif; ?>
                <?= $escaper->escapeHtml($item['name']) ?>
            </div>

            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                <path d="M9 18L15 12L9 6" stroke="black" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </button>

        <ul
            id="<?= $escaper->escapeHtmlAttr($item['id']) ?>-desktop-menu-panel"
            class="absolute inset-0 w-72 translate-x-72 bg-teakea-cream flex flex-col gap-1"
            x-show="subMenuOpen<?= $menuId ?>"
            x-ref="childmenuWrapper<?= $menuId ?>"
            @keydown.escape.stop="subMenuOpen<?= $menuId ?> = false;
                $refs.childmenuToggle<?= $menuId ?>.focus();">
            <?php foreach ($item['childData'] as $subMenu): ?>
                <?= $block->getLayout()
                    ->getBlock('topmenu_desktop_item')
                    ->setItem($subMenu)
                    ->setLevel($level + 1)
                    ->toHtml() ?>
            <?php endforeach; ?>

            <li class="col-span-2 text-center pt-3.5 pb-6 px-8 border-t border-[#00000033]">
                <a
                    href="<?= $escaper->escapeUrl($item['url']) ?>"
                    class="flex py-3 px-2 text-center justify-center uppercase aria-[current=page]:font-semibold
                           border border-black font-semibold text-sm text-[#1e1e1e]"
                    x-ref="childmenuViewAll<?= $menuId ?>">
                    <?= $escaper->escapeHtml(__('See all %1', $item['name'])) ?>
                </a>
            </li>
        </ul>
    </li>
<?php else: ?>
    <li class="level-<?= $level ?> flex flex-row items-center py-3.5 px-8 gap-x-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
            aria-hidden="true" class="w-3 h-3">
            <circle cx="12" cy="12" r="6"></circle>
        </svg>
        <a
            href="<?= $escaper->escapeUrl($item['url']) ?>"
            class="level-<?= $level ?> flex text-black text-base aria-[current=page]:text-teakea-red">
            <?= $escaper->escapeHtml($item['name']) ?>
        </a>
    </li>
<?php endif; ?>