// ── Showroom status ───────────────────────────────────────────────────────
$now = new \DateTime('now', new \DateTimeZone('Europe/Amsterdam'));
$currentDay = (int)$now->format('w');
$currentTime = $now->format('H:i');

$openingHours = array_fill_keys(range(0, 6), [
    'open'  => '08:30',
    'close' => '17:30'
]);

$openingHours[6] = ['open' => '09:00', 'close' => '17:00']; // Saturday
$openingHours[0] = null; // Sunday closed

$todaySchedule = $openingHours[$currentDay] ?? null;

$isOpen = $todaySchedule
    && $currentTime >= $todaySchedule['open']
    && $currentTime < $todaySchedule['close'];

if ($isOpen) {
    $statusText = __('Open today until %1', $todaySchedule['close']);
} else {
    $nextLabel = null;
    $nextOpenTime = null;

    for ($i = 1; $i <= 7; $i++) {
        $day = ($currentDay + $i) % 7;

        if (!empty($openingHours[$day])) {
            $nextLabel = $i === 1
                ? (string)__('tomorrow')
                : (clone $now)->modify("+{$i} days")->format('l');

            $nextOpenTime = $openingHours[$day]['open'];
            break;
        }
    }
    $statusText = $nextLabel ? __('Opens %1 at %2', $nextLabel, $nextOpenTime) : __('Currently closed');
}

