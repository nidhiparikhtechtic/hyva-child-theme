<script>
    'use strict';

    const initMenuMobile<?= $escaper->escapeHtml($uniqueId) ?> = () => {
        return {
            open: false,
            loggedIn: false,
            savedScrollPosition: 0,
            activeAccordion: null,
            init() {
                window.addEventListener('private-content-loaded', (event) => {
                    const customer = event.detail?.data?.customer;
                    this.loggedIn = !!(customer && customer.firstname);
                });
            },
            setActiveMenu(menuNode) {
                Array.from(menuNode.querySelectorAll('a')).filter(link => {
                    return link.href === window.location.href.split('?')[0];
                }).forEach(item => {
                    item.classList.add('underline');
                    item.closest('li.level-0') &&
                        item.closest('li.level-0').querySelector('a.level-0') &&
                        item.closest('li.level-0').querySelector('a.level-0').classList.add('underline');
                });
            },
            openMenu() {
                this.savedScrollPosition = window.scrollY;
                document.body.style.position = 'fixed';
                document.body.style.top = `-${this.savedScrollPosition}px`;
                this.open = true;
                this.$nextTick(() => hyva.trapFocus(this.$refs['mobileMenuNavLinks']));
            },
            closeMenu() {
                document.body.style.position = '';
                document.body.style.top = '';
                window.scrollTo(0, this.savedScrollPosition);
                if (this.open) {
                    this.$nextTick(() => this.$refs['mobileMenuTrigger'].focus() || hyva.releaseFocus());
                }
                this.open = false;
                this.activeAccordion = null;
                // Close all open accordions when menu closes
                document.querySelectorAll('.menu-accordion-body.is-open').forEach(el => el.classList.remove('is-open'));
                document.querySelectorAll('.menu-accordion-chevron.is-open').forEach(el => el.classList.remove('is-open'));
            }
        }
    }
</script>