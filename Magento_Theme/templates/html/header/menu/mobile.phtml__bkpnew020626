$viewModelNavigation = $viewModels->require(Navigation::class, $block);
$uniqueId           = '_' . uniqid();
$menuItems          = $viewModelNavigation->getNavigation(4);
$block->setData('cache_tags', $viewModelNavigation->getIdentities());

// ── Showroom status ───────────────────────────────────────────────────────
$scopeConfig  = \Magento\Framework\App\ObjectManager::getInstance()
    ->get(\Magento\Framework\App\Config\ScopeConfigInterface::class);

$openTime   = '09:00';
$closeTime  = '17:30';
$weekendDays = array_map('intval', array_filter(
    explode(',', $scopeConfig->getValue('general/locale/weekend', ScopeInterface::SCOPE_STORE) ?: '0'),
    fn($v) => $v !== ''
));
$openDays   = array_values(array_diff([0, 1, 2, 3, 4, 5, 6], $weekendDays));

$now         = new \DateTime('now', new \DateTimeZone('Europe/Amsterdam')); // Current time in Amsterdam timezone
$currentDay  = (int)$now->format('w'); // PHP: 0=Sun … 6=Sat
$currentTime = $now->format('H:i');    // e.g. "14:35"
$isOpen      = in_array($currentDay, $openDays, true) && $currentTime >= $openTime && $currentTime < $closeTime;

if ($isOpen) {
    $statusText = __('Open today until %1', $closeTime);
} else {
    $nextLabel = null;
    for ($i = 1; $i <= 7; $i++) {
        if (in_array(($currentDay + $i) % 7, $openDays, true)) {
            $nextLabel = $i === 1 ? (string)__('tomorrow') : (clone $now)->modify("+{$i} days")->format('l');
            break;
        }
    }
    $statusText = $nextLabel ? __('Opens %1 at %2', $nextLabel, $openTime) : __('Currently closed');
}
// ── End showroom status ────────────────────────────────────────────────────

