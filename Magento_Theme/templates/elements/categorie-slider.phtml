                                <div class="font-normal text-base mx-auto break-word hyphens-auto pt-2">
                                    <?= $escaper->escapeHtml($categoryName) ?>
                                </div>
                            </a>
                        </div>
                    <?php endforeach; ?>

                </div>
            </div>
        </div>



        <!-- Pagination -->
        <div>
            <template x-if="itemCount > pageSize">
                <div class="flex items-center justify-between md:container absolute top-1/4 right-0 left-0 !px-0 w-full">
                    <button
                        aria-label="<?= $escaper->escapeHtml(__('Previous')) ?>"
                        tabindex="-1"
                        class="text-black rounded-full outline-none focus:outline-none flex-none lg:block z-10"
                        :class="{ 'opacity-[0] pointer-events-none' : active === 0 }"
