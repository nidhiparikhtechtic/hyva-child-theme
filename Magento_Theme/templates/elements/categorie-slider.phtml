                    </button>

                    <button
                        aria-label="<?= $escaper->escapeHtml(__('Next')) ?>"
                        tabindex="-1"
                        class=" text-black rounded-full outline-none focus:outline-none flex-none lg:block z-10"
                        :class="{ 'opacity-[0] pointer-events-none' : active >= itemCount-pageSize }"
                        @click="scrollNext">
                        <?= $heroicons->arrowNarrowRightHtml("p-3 stroke-black h-[45px] sm:h-[50px] w-[45px] sm:w-[50px] lg:h-[45px] lg:w-[45px] rounded-full bg-white stroke-1 ", 24, 24) ?>
                    </button>
                </div>
            </template>
        </div>
    </div>
</section>