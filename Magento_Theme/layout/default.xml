<page layout="3columns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="hyva_modal" />
    <update handle="hyva_form_validation" />
    <body>
        <referenceContainer name="before.body.end">
            <block
                name="techtic.furniture.store.schema.home"
                template="Magento_Theme::schema/furniture-store.phtml" />
        </referenceContainer>

        <referenceContainer name="page.wrapper"
            htmlClass="page-wrapper min-h-screen bg-white flex flex-col" />
        <referenceContainer name="main.content" htmlClass="page-main bg-white flex-grow" />

        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\FormKey" name="formkey" />
        </referenceContainer>

        <referenceContainer name="page.messages">
            <block class="Magento\Framework\View\Element\Messages"
                name="messages"
                as="messages"
                template="Magento_Theme::messages.phtml"
            />
        </referenceContainer>

        <referenceContainer name="main.content">
            <block class="Magento\Framework\View\Element\Template" name="skip_to_content.target"
                before="-" template="Magento_Theme::html/skiptarget.phtml">
                <arguments>
                    <argument name="target_id" xsi:type="string">contentarea</argument>
                </arguments>
            </block>
        </referenceContainer>

        <referenceBlock name="page.wrapper">
            <block name="header-usps" template="Magento_Theme::html/header/usps.phtml"
                before="header.container" />
        </referenceBlock>

        <referenceContainer name="header.container">
            <block class="Magento\Framework\View\Element\Template" name="skip_to_content"
                template="Magento_Theme::html/skip.phtml" before="-">
                <arguments>
                    <argument name="target" xsi:type="string">contentarea</argument>
                    <argument name="label" translate="true" xsi:type="string">Skip to Content</argument>
                </arguments>
            </block>
            <referenceBlock name="header-content" template="Magento_Theme::html/header.phtml">
                <block class="Magento\Theme\Block\Html\Header\Logo" name="logo">
                    <arguments>
                        <argument name="logoPathResolver" xsi:type="object">
                            Hyva\Theme\ViewModel\Logo\LogoPathResolver</argument>
                        <!-- These values are used if no width or height is set in the adminhtml
                        theme configuration -->
                        <argument name="logo_width" xsi:type="number">189</argument>
                        <argument name="logo_height" xsi:type="number">64</argument>
                    </arguments>
                </block>
                <block name="header-search" template="Magento_Theme::html/header/search-form.phtml" />
                <block name="cart-drawer" template="Magento_Theme::html/cart/cart-drawer.phtml"
                    ifconfig="checkout/sidebar/display">
                    <block name="cart-drawer-loading" as="loading"
                        template="Hyva_Theme::ui/loading.phtml" />
                    <block class="Magento\Checkout\Block\QuoteShortcutButtons" name="extra_actions" />
                    <container name="cart-drawer.top" />
                    <container name="cart-drawer.items.before" />
                    <container name="cart-drawer.totals.before" />
                    <container name="cart-drawer.bottom" />
                </block>

                <block name="topmenu_generic"
                    as="topmenu"
                    template="Magento_Theme::html/header/topmenu.phtml"
                >
                    <arguments>
                        <argument name="cache_lifetime" xsi:type="string">3600</argument>
                    </arguments>
                    <block name="topmenu_mobile"
                        as="topmenu.mobile"
                        template="Magento_Theme::html/header/menu/mobile.phtml"
                    ></block>

                    <block name="topmenu_desktop"
                        as="topmenu.desktop"
                        template="Magento_Theme::html/header/menu/desktop.phtml"
                    ></block>
                </block>
            </referenceBlock>
        </referenceContainer>

        <!-- <referenceBlock name="topmenu_desktop">
            <arguments>
                <argument name="open_top_level_menu_on_hover" xsi:type="boolean">true</argument>
                <argument name="max_level" xsi:type="number">3</argument>
                <argument name="top_menu_cta_item" xsi:type="string" translate="true">Sale</argument>
            </arguments>
            <block
                name="topmenu_desktop_item"
                template="Magento_Theme::html/header/menu/desktop-item.phtml"
            />
        </referenceBlock> -->

        <referenceBlock name="topmenu_desktop">
            <arguments>
                <argument name="open_top_level_menu_on_hover" xsi:type="boolean">true</argument> <!--
                Also open on hover (true/false)-->
                <argument name="show_top_level_all_link" xsi:type="boolean">true</argument> <!--
                Show view all link for top level (true/false) -->
                <argument name="top_menu_cta_item" xsi:type="string" translate="true">Sale</argument> <!--
                Top Menu Item to Highlight -->
            </arguments>
        </referenceBlock>

        <referenceContainer name="top.container">
            <block class="Magento\Theme\Block\Html\Breadcrumbs" name="breadcrumbs" as="breadcrumbs" />
        </referenceContainer>

        <referenceContainer name="columns.top">
            <block class="Magento\Theme\Block\Html\Title" name="page.main.title"
                template="Magento_Theme::html/title.phtml" />
        </referenceContainer>

        <referenceContainer name="footer" htmlClass="border-t-[0.5px] border-black">
            <block name="footer-content" template="Magento_Theme::html/footer.phtml">
                <block name="footer-static-links" template="Magento_Theme::html/footer/links.phtml" />
                <block class="Magento\Cms\Block\Block" name="footer-cms-content">
                    <arguments>
                        <argument name="block_id" xsi:type="string">footer_content</argument>
                    </arguments>
                </block>
                <block class="Magento\Theme\Block\Html\Footer" name="footer-copyright"
                    template="Magento_Theme::html/footer/copyright.phtml" as="copyright" />
            </block>
        </referenceContainer>

        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Js\Components" name="head.components"
                as="components" template="Magento_Theme::html/container.phtml" />
        </referenceContainer>

        <referenceContainer name="before.body.end">
            <block class="Magento\Theme\Block\Html\Footer" name="absolute_footer"
                template="Magento_Theme::html/absolute_footer.phtml" />

            <block class="Magento\Framework\View\Element\Template"
                name="auth.modal"
                template="Magento_Customer::account/auth-modal.phtml">

                <block class="Magento\Customer\Block\Form\Login"
                    name="form.login"
                    as="form.login"
                    template="Magento_Customer::form/login.phtml">
                    <container name="form.additional.info" as="form_additional_info" />
                </block>

                <block class="Magento\Customer\Block\Form\Register"
                    name="form.register"
                    as="form.register"
                    template="Magento_Customer::form/register.phtml">
                    <arguments>
                        <argument name="attribute_data" xsi:type="object">
                            Magento\Customer\Block\DataProviders\AddressAttributeData</argument>
                        <argument name="post_code_config" xsi:type="object">
                            Magento\Customer\Block\DataProviders\PostCodesPatternsAttributeData</argument>
                    </arguments>
                    <container name="form.additional.info" as="form_additional_info" />
                    <container name="fieldset.create.info.additional"
                        as="fieldset_create_info_additional" />
                    <container name="customer.form.register.fields.before" as="form_fields_before"
                        label="Form Fields Before" htmlTag="div" htmlClass="customer-form-before" />
                </block>

            </block>
            <block name="password.validate.js"
                template="Magento_Customer::js/password-validation.phtml" />
        </referenceContainer>

        <referenceContainer name="form.additional.info">
            <block name="form_additional_info_customer"
                template="Magento_Customer::additionalinfocustomer.phtml" />
        </referenceContainer>

        <block class="Magento\Framework\View\Element\Template" name="head.additional"
            as="head.additional" template="Magento_Theme::html/container.phtml">
            <block name="js.sticky.header" template="Magento_Theme::page/js/sticky-header.phtml">
                <arguments>
                    <argument name="hide_on_scroll_down" xsi:type="boolean">true</argument> <!-- Hide
                    sticky header on scroll down (true/false) -->
                    <argument name="scroll_offset" xsi:type="number">100</argument> <!-- Offset
                    before the helper reflects the scrollDir -->
                    <argument name="enable_css_only_sticky_style" xsi:type="boolean">false</argument> <!--
                    Enable CSS only solution (true/false) -->
                </arguments>
            </block>

            <block class="Magento\Framework\View\Element\Template"
                name="triplepixel.init"
                template="Magento_Theme::triplepixel-init.phtml" />
        </block>
        <referenceBlock name="script-alpine-js">
            <block name="js.scroll.helpers" template="Magento_Theme::page/js/scroll-helpers.phtml" />
            <block name="alpine-plugin-collapse"
                template="Magento_Theme::page/js/plugins/collapse.phtml" />
        </referenceBlock>


    </body>
</page>