<page layout="3columns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="hyva_product_slider" />

    <head>
        <link rel="canonical" src="{{baseUrl}}" src_type="url" />
    </head>

    <body>
        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                name="custom.preload.images"
                template="Magento_Theme::html/preload.phtml" />
        </referenceContainer>
        
        <referenceContainer name="content">
            <block name="hero" template="Magento_Theme::elements/hero.phtml" />
            <block name="content-1" template="Magento_Theme::elements/content-1.phtml" />
        </referenceContainer>

        <referenceBlock name="page.main.title" remove="true" />
        <referenceBlock name="hero" remove="true" />
        <referenceBlock name="content-1" remove="true" />
        <referenceBlock name="slider-1" remove="true" />
        <referenceBlock name="slider-2" remove="true" />
    </body>
</page>