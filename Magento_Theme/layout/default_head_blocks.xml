                  src="fonts/Mulish/Mulish-Bold.woff2"
                  crossorigin="anonymous" />

            <link rel="preload" as="font" type="font/woff2"
                  src="fonts/Mulish/Mulish-ExtraBold.woff2"
                  crossorigin="anonymous" />

            <script src="js/auth-modal-store.js" />
